  <!-- AUTHENTICATION -->
  <Config Name="Auth Type" Target="AUTHTYPE" Default="none" Mode="" Description="Authentication method: none, basic, entra, or google" Type="Variable" Display="always" Required="true" Mask="false"/>

  <!-- BASIC AUTH -->
  <Config Name="Basic Auth Credentials" Target="BASIC_AUTH_CREDENTIALS" Default="" Mode="" Description="For AUTHTYPE=basic. Format: user1:pass1|user2:pass2" Type="Variable" Display="always" Required="false" Mask="true"/>

  <!-- ENTRA ID (MICROSOFT) -->
  <Config Name="Entra Client ID" Target="ENTRA_CLIENT_ID" Default="" Mode="" Description="For AUTHTYPE=entra. Azure AD application ID" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Entra Client Secret" Target="ENTRA_CLIENT_SECRET" Default="" Mode="" Description="For AUTHTYPE=entra. Azure AD application secret" Type="Variable" Display="always" Required="false" Mask="true"/>
