  <Config Name="Google Client Secret" Target="GOOGLE_CLIENT_SECRET" Default="" Mode="" Description="For AUTHTYPE=google. From Google Cloud Console" Type="Variable" Display="always" Required="false" Mask="true"/>
  <Config Name="Google Redirect URI" Target="GOOGLE_REDIRECT_URI" Default="https://yourdomain.com" Mode="" Description="For AUTHTYPE=google. Just the domain root (no path). Must match Google OAuth configuration" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Google Crypto Passphrase" Target="GOOGLE_CRYPTO_PASSPHRASE" Default="" Mode="" Description="For AUTHTYPE=google. Session encryption key (auto-generated if blank)" Type="Variable" Display="advanced" Required="false" Mask="true"/>
  <Config Name="OIDC Provider Metadata URL" Target="OIDC_PROVIDER_METADATA_URL" Default="" Mode="" Description="Azure AD OIDC metadata URL (e.g., https://login.microsoftonline.com/{tenant-id}/v2.0/.well-known/openid-configuration)" Type="Variable" Display="always" Required="false" Mask="false"/>
  
  <!-- PORTS -->
  <Config Name="HTTP Port" Target="HostPort" Default="80" Mode="tcp" Description="HTTP Port" Type="Port" Display="always" Required="false" Mask="false">80</Config>
  <Config Name="HTTPS Port" Target="HostPort" Default="443" Mode="tcp" Description="HTTPS Port" Type="Port" Display="always" Required="false" Mask="false">443</Config>
  
  <!-- VOLUMES -->
  <Config Name="Certificates Volume" Target="/etc/letsencrypt" Default="/mnt/user/appdata/apache-reverse-proxy/letsencrypt" Mode="rw" Description="SSL Certificates" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/apache-reverse-proxy/letsencrypt</Config>
  <Config Name="Logs Volume" Target="/var/log/apache2" Default="/mnt/user/appdata/apache-reverse-proxy/logs" Mode="rw" Description="Apache Logs" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/appdata/apache-reverse-proxy/logs</Config>
  <Config Name="HTML Volume" Target="/var/www/html" Default="/mnt/user/appdata/apache-reverse-proxy/html" Mode="rw" Description="HTML Dashboard" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/appdata/apache-reverse-proxy/html</Config></Container>
