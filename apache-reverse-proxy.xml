<?xml version="1.0" encoding="utf-8"?>
<Container version="2">
  <Name>Apache-Reverse-Proxy</Name>
  <Repository>auskento/apache-reverse-proxy:latest</Repository>
  <Registry>https://hub.docker.com/</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/auskento/apache-reverse-proxy</Support>
  <Project>https://github.com/auskento/apache-reverse-proxy</Project>
  <Category>Network:Web</Category>
  <TemplateURL>https://raw.githubusercontent.com/auskento/apache-reverse-proxy/main/apache-reverse-proxy.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/auskento/apache-reverse-proxy/main/apache-reverse-proxy-150.png</Icon>
  <PostArgs/>
  <CloudSync>false</CloudSync>
  <Description>Apache Reverse Proxy with Let's Encrypt HTTPS, modular service proxying, and three authentication methods: Basic Auth, Entra ID (Microsoft), or Google OAuth2.</Description>
  <Overview>Apache Reverse Proxy for Media Services&#13;&#13;This container provides:&#13;- Automatic HTTPS with Let's Encrypt SSL certificates&#13;- Reverse proxy for up to 14 different services&#13;- Web dashboard with service icons and navigation&#13;- Three authentication options: Basic Auth, Entra ID (Microsoft), or Google OAuth2&#13;- Custom service icons via icon URLs&#13;&#13;Quick Start:&#13;1. Set Domain and Email (required for Let's Encrypt)&#13;2. Choose authentication method (AUTHTYPE: none, basic, entra, or google)&#13;3. Enable services by toggling each service switch&#13;4. Configure backend URLs for each enabled service&#13;5. Container will auto-generate dashboard with enabled services&#13;&#13;Supported Services:&#13;SABnzbd, Deluge, Transmission, qBittorrent, Radarr, Sonarr, Whisparr, Prowlarr, Seerr, Lidarr, Emby, Plex, Jellyfin, Tautulli&#13;&#13;Authentication Options:&#13;- Basic Auth: Simple username/password (forces classic interface)&#13;- Entra ID: Microsoft Azure AD authentication (modern dashboard)&#13;- Google: Google account/Workspace authentication (modern dashboard)&#13;- None: No authentication required&#13;&#13;Documentation:&#13;https://github.com/auskento/apache-reverse-proxy</Overview>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>80</HostPort>
        <ContainerPort>80</ContainerPort>
        <Protocol>tcp</Protocol>
        <Description>HTTP</Description>
        <Access>External</Access>
      </Port>
      <Port>
        <HostPort>443</HostPort>
        <ContainerPort>443</ContainerPort>
        <Protocol>tcp</Protocol>
        <Description>HTTPS</Description>
        <Access>External</Access>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/apache-reverse-proxy/letsencrypt</HostDir>
      <ContainerDir>/etc/letsencrypt</ContainerDir>
      <Mode>rw</Mode>
      <Description>SSL Certificates</Description>
      <Access>rw</Access>
      <Exclude/>
      <IsFileShare>false</IsFileShare>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/apache-reverse-proxy/logs</HostDir>
      <ContainerDir>/var/log/apache2</ContainerDir>
      <Mode>rw</Mode>
      <Description>Apache Logs</Description>
      <Access>rw</Access>
      <Exclude/>
      <IsFileShare>false</IsFileShare>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/apache-reverse-proxy/html</HostDir>
      <ContainerDir>/var/www/html</ContainerDir>
      <Mode>rw</Mode>
      <Description>HTML Dashboard</Description>
      <Access>rw</Access>
      <Exclude/>
      <IsFileShare>false</IsFileShare>
    </Volume>
  </Data>
  
