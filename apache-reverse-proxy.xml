  <Labels/>
  
  <!-- FORM CONFIGURATION - These appear in Unraid UI -->
  <Config Name="DOMAIN" Target="DOMAIN" Default="yourdomain.com" Mode="" Description="Domain Name (REQUIRED - e.g., example.com)" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="EMAIL" Target="EMAIL" Default="admin@example.com" Mode="" Description="Email for Let's Encrypt (REQUIRED)" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Timezone" Target="TZ" Default="Australia/Melbourne" Mode="" Description="Timezone" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Dashboard Style" Target="STYLE" Default="modern" Mode="" Description="Dashboard style (classic or modern)" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Dashboard Name" Target="DASHBOARD_NAME" Default="Media Server" Mode="" Description="Custom dashboard title (e.g., My Homelab)" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Dashboard Icon" Target="DASHBOARD_ICON" Default="/icons/apache-reverse-proxy-logo.png" Mode="" Description="Dashboard icon path (e.g., /icons/custom-logo.png - place files in html/icons)" Type="Variable" Display="always" Required="false" Mask="false"/>
  
