  <Config Name="Entra Provider Metadata URL" Target="ENTRA_PROVIDER_METADATA_URL" Default="" Mode="" Description="For AUTHTYPE=entra. e.g., https://login.microsoftonline.com/YOUR_TENANT_ID/v2.0/.well-known/openid-configuration" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Entra Crypto Passphrase" Target="ENTRA_CRYPTO_PASSPHRASE" Default="" Mode="" Description="For AUTHTYPE=entra. Session encryption key (auto-generated if blank)" Type="Variable" Display="advanced" Required="false" Mask="true"/>

  <!-- GOOGLE OAUTH -->
