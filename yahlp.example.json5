{
  // ============================================================================
  // YAHLP Configuration File (JSON5 Format)
  // ============================================================================
  //
  // This is the primary configuration file for YAHLP. It defines all settings
  // for the dashboard, services, authentication, and more.
  //
  // To use this configuration:
  // 1. Copy this file to yahlp.json5
  // 2. Update values for your environment
  // 3. Mount it in Docker: -v $(pwd)/yahlp.json5:/etc/yahlp/yahlp.json5
  //
  // All configuration is read from this file when the proxy starts.
  // Environment variables can override any value in this file.
  //
  // ============================================================================

  // Dashboard UI Configuration
  // Environment Variables: DASHBOARD_NAME, DASHBOARD_COLOR, DASHBOARD_STYLE, DASHBOARD_ORDER, DASHBOARD_LANDING
  dashboard: {
    // Name displayed in the browser title and welcome screen
    name: 'My Dashboard',

    // URL for alternate icon displayed in the dashboard
    icon_url: '',

    // Primary color used in the UI
    color: '#00A99D',

    // Theme: 'dark' or 'light'
    theme: 'dark',

    // Layout style: 'classic', 'modern', 'sleek', 'minimal'
    // or custom template name 
	// Single name to build all templates and enable slider
	// Comma separated to only build listed styles, first as default
	// Use :only to build single menu item only
    style: 'classic',

    // Landing page: Blank shows srvice panel or welcome
	// set a service as home, radarr or sonarr/calendar
    landing: 'dashboard',

    // Service display order on dashboard (use 3-letter service codes)
    // Arrange services as desired; only enabled services will be shown
    // USENET: SAB=SABnzbd, GET=NZBGet, HYD=NZBHydra
    // TORRENTS: TRA=Transmission, QBI=qBittorrent, DEL=Deluge
    // SEARCH: PRO=Prowlarr, JAC=Jackett, SON=Sonarr, RAD=Radarr, LID=Lidarr, WHI=Whisparr
    // INFRASTRUCTURE: SEE=Seerr, BAZ=Bazarr, TAU=Tautulli, MNT=Maintainerr
    // MEDIA: JEL=Jellyfin, PLX=Plex, EMB=Emby
	// SEPERATORS: SEP=Blank separator, VIS=Line separator, LBL:Text=Label with text
    order: [
      'SAB', 'GET', 'HYD',
      'TRA', 'QBI', 'DEL',
      'PRO', 'JAC', 'SON', 'RAD', 'LID', 'WHI',
      'SEE', 'BAZ', 'TAU', 'MNT',
      'JEL', 'PLX', 'EMB',
    ],

    // Built-in torrent/usenet sites to enable (optional)
    // Torrent site codes: TPB, FIL, HDB, IPT, 1337, YTS, LAT, NYA, PTP
    // Usenet site codes: DOG, DRS, NLF, NFW, NGK, PLA, TAB
    // Example: sites: ['TPB', 'DOG', 'NLF'] shows The Pirate Bay, DOGnzb, nzb.life
    // Can also be set via DASHBOARD_SITES environment variable (takes precedence)
    sites: [
      // 'TPB', 'DOG', 'NLF',
    ],
  },

  // Access Mode Configuration
  // Environment Variables: ACCESS_MODE, DOMAIN, EMAIL, IP
  access: {
    // Mode: 'private' (localhost only) or 'public' (domain with HTTPS)
    mode: 'private',

    // Only used when mode is 'public':
    // Domain name for the dashboard (used with Let's Encrypt SSL)
    domain: 'dashboard.example.com',

    // Only used when mode is 'public':
    // Email for Let's Encrypt certificate registration
    email: 'admin@example.com',
  },

  // Authentication Configuration
  // Environment Variables: AUTHTYPE, BASIC_AUTH_CREDENTIALS
  auth: {
    // Type: 'none', 'basic', 'google', or 'entra'
    type: 'none',

    // For basic auth, include credentials: username:password|username2:password2
    basic_credentials: '',
  },

  // Check AUTHENTICATION.md to see how to create the credentials for Google and Entra
  // Google OAuth Configuration (if auth.type is 'google')
  // Environment Variables: GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, GOOGLE_REDIRECT_URI, 
  
  google: {
    client_id: 'your-google-client-id',
    client_secret: 'your-google-client-secret',
    redirect_uri: 'http://localhost:3000/auth/callback',
  },
  */

  // Entra/Azure AD Configuration (if auth.type is 'entra')
  // Environment Variables: ENTRA_CLIENT_ID, ENTRA_CLIENT_SECRET, ENTRA_REDIRECT_URI, ENTRA_PROVIDER_METADATA_URL, ENTRA_CRYPTO_PASSPHRASE
  /*
  entra: {
    client_id: 'your-entra-client-id',
    client_secret: 'your-entra-client-secret',
    redirect_uri: 'http://localhost:3000/auth/callback',
    provider_metadata_url: 'https://login.microsoftonline.com/common/v2.0/.well-known/openid-configuration',
    crypto_passphrase: 'your-secret-passphrase',
  },
  */

  // Service Configurations
  // Each service can be enabled/disabled with the 'enabled' field
  // Services have different required parameters based on type
  // General format: {SERVICE}_ENABLED, {SERVICE}_URL, {SERVICE}_API_KEY, {SERVICE}_ICON_URL
  services: {
    // ========== Media Servers ==========
    // Env: JELLYFIN_ENABLED, JELLYFIN_URL, JELLYFIN_API_KEY, JELLYFIN_ICON_URL
    // Env: PLEX_ENABLED, PLEX_URL, PLEX_API_KEY, PLEX_ICON_URL
    // Env: EMBY_ENABLED, EMBY_URL, EMBY_API_KEY, EMBY_ICON_URL

    // Jellyfin: Media Server
    // Env: JELLYFIN_ENABLED, JELLYFIN_URL, JELLYFIN_API_KEY, JELLYFIN_ICON_URL
    jellyfin: {
      enabled: true,
      url: 'http://jellyfin:8096',
      api_key: 'your-jellyfin-api-key-here',
      icon_url: '', // URL for alternate Jellyfin icon
    },

    // Plex: Media Server
    // Requires: domain_name and redirect_uri for authentication
    // Env: PLEX_ENABLED, PLEX_URL, PLEX_API_KEY, PLEX_ICON_URL
    plex: {
      enabled: true,
      url: 'http://plex:32400',
      api_key: 'your-plex-api-key-here',
      icon_url: '', // URL for alternate Plex icon
      domain_name: 'plex.example.com',
      redirect_uri: 'https://plex.yourdomain.com/oauth2/callback',
    },

    // Emby: Media Server
    // Requires: domain_name and redirect_uri for authentication
    // Env: EMBY_ENABLED, EMBY_URL, EMBY_API_KEY, EMBY_ICON_URL
    emby: {
      enabled: false,
      url: 'http://emby:8096',
      api_key: 'your-emby-api-key-here',
      icon_url: '', // URL for alternate emby icon
      domain_name: 'emby.example.com',
      redirect_uri: 'https://emby.yourdomain.com/oauth2/callback',
    },

    // ========== Usenet Services ==========
    // Env: SABNZBD_ENABLED, SABNZBD_URL, SABNZBD_API_KEY, SABNZBD_ICON_URL
    // Env: NZBGET_ENABLED, NZBGET_URL, NZBGET_USER, NZBGET_PASS, NZBGET_ICON_URL
    // Env: NZBHYDRA_ENABLED, NZBHYDRA_URL, NZBHYDRA_API_KEY, NZBHYDRA_ICON_URL

    // SABnzbd: Usenet Client
    // Env: SABNZBD_ENABLED, SABNZBD_URL, SABNZBD_API_KEY, SABNZBD_ICON_URL
    sabnzbd: {
      enabled: false,
      url: 'http://sabnzbd:8080',
      api_key: 'your-sabnzbd-api-key-here',
      icon_url: '', // URL for alternate Sabnzbd icon
    },

    // NZBGet: Usenet Client
    // Requires: username + password (not api_key)
    // Env: NZBGET_ENABLED, NZBGET_URL, NZBGET_USER, NZBGET_PASS, NZBGET_ICON_URL
    nzbget: {
      enabled: false,
      url: 'http://nzbget:6789',
      username: 'nzbget',  // This will bypass the separate login that NZBGet has
      password: 'tegbzn6789',
      icon_url: '', // URL for alternate NZBGet icon
    },

    // NZBHydra2: Usenet Meta-Search
    // Env: NZBHYDRA_ENABLED, NZBHYDRA_URL, NZBHYDRA_API_KEY, NZBHYDRA_ICON_URL
    nzbhydra: {
      enabled: false,
      url: 'http://nzbhydra:5076',
      api_key: 'your-nzbhydra-api-key-here',
      icon_url: '', // URL for alternate NZBHydra icon
    },

    // ========== Torrent Services ==========
    // Env: TRANSMISSION_ENABLED, TRANSMISSION_URL, TRANSMISSION_ICON_URL
    // Env: QBITTORRENT_ENABLED, QBITTORRENT_URL, QBITTORRENT_API_KEY, QBITTORRENT_ICON_URL
    // Env: DELUGE_ENABLED, DELUGE_URL, DELUGE_API_KEY, DELUGE_ICON_URL

    // Transmission: Torrent Client
    // Requires: URL only (no authentication needed)
    // Env: TRANSMISSION_ENABLED, TRANSMISSION_URL, TRANSMISSION_ICON_URL
    transmission: {
      enabled: false,
      url: 'http://transmission:9091',
      icon_url: '', // URL for alternate QbitTorrent icon
    },

    // qBittorrent: Torrent Client
    // Requires: API key (no username/password)
    // Env: QBITTORRENT_ENABLED, QBITTORRENT_URL, QBITTORRENT_API_KEY, QBITTORRENT_ICON_URL
    qbittorrent: {
      enabled: false,
      url: 'http://qbittorrent:8080',
      api_key: 'your-api-key',
      icon_url: '', // URL for alternate QBitTorrent icon
    },

    // Deluge: Torrent Client
    // Requires: password (for web UI login)
    // Env: DELUGE_ENABLED, DELUGE_URL, DELUGE_API_KEY, DELUGE_ICON_URL
    deluge: {
      enabled: false,
      url: 'http://deluge:8112',
      password: 'deluge',  // This will allow pre-auth of your Deluge session and bypass login prompt
      icon_url: '', // URL for alternate deluge icon    },

    // ========== Search & Automation Services ==========
    // Env: PROWLARR_ENABLED, PROWLARR_URL, PROWLARR_API_KEY, PROWLARR_ICON_URL
    // Env: JACKETT_ENABLED, JACKETT_URL, JACKETT_API_KEY, JACKETT_ICON_URL
    // Env: SONARR_ENABLED, SONARR_URL, SONARR_API_KEY, SONARR_ICON_URL
    // Env: RADARR_ENABLED, RADARR_URL, RADARR_API_KEY, RADARR_ICON_URL
    // Env: LIDARR_ENABLED, LIDARR_URL, LIDARR_API_KEY, LIDARR_ICON_URL
    // Env: WHISPARR_ENABLED, WHISPARR_URL, WHISPARR_API_KEY, WHISPARR_ICON_URL

    // Prowlarr: Indexer Manager
    // Env: PROWLARR_ENABLED, PROWLARR_URL, PROWLARR_API_KEY, PROWLARR_ICON_URL
    prowlarr: {
      enabled: true,
      url: 'http://prowlarr:9696',
      api_key: 'your-prowlarr-api-key-here',
      icon_url: '', // URL for alternate Prowlarr icon
    },

    // Jackett: Indexer Aggregator
    // Env: JACKETT_ENABLED, JACKETT_URL, JACKETT_API_KEY, JACKETT_ICON_URL
    jackett: {
      enabled: false,
      url: 'http://jackett:9117',
      api_key: 'your-jackett-api-key-here',
      icon_url: '', // URL for alternate Jackett icon
    },

    // Sonarr: TV Show Management
    // Optional landing option to set default page (e.g., calendar)
    // Env: SONARR_ENABLED, SONARR_URL, SONARR_API_KEY, SONARR_ICON_URL
    sonarr: {
      enabled: true,
      url: 'http://sonarr:8989',
      api_key: 'your-sonarr-api-key-here',
      icon_url: '', // URL for alternate Sonarr icon
      landing: 'sonarr', // Default page to open (e.g., sonarr/calendar instead of root)
    },

    // Radarr: Movie Management
    // Optional landing option to set default page (e.g., movies, history)
    // Env: RADARR_ENABLED, RADARR_URL, RADARR_API_KEY, RADARR_ICON_URL
    radarr: {
      enabled: true,
      url: 'http://radarr:7878',
      api_key: 'your-radarr-api-key-here',
      icon_url: '', // URL for alternate Radarr icon
      landing: 'radarr', // Default page to open (radarr/calendar)
    },

    // Lidarr: Music Management
    // Optional landing option to set default page (e.g., albums, wanted)
    // Env: LIDARR_ENABLED, LIDARR_URL, LIDARR_API_KEY, LIDARR_ICON_URL
    lidarr: {
      enabled: true,
      url: 'http://lidarr:8686',
      api_key: 'your-lidarr-api-key-here',
      icon_url: '', // URL for alternate Lidarr icon
      landing: 'lidarr', // Default page to open (lidarr/albums)
    },

    // Whisparr: Adult Content Management
    // Optional landing option to set default page
    // Env: WHISPARR_ENABLED, WHISPARR_URL, WHISPARR_API_KEY, WHISPARR_ICON_URL
    whisparr: {
      enabled: false,
      url: 'http://whisparr:6969',
      api_key: 'your-whisparr-api-key-here',
      icon_url: '', // URL for alternate Whisparr icon
      landing: 'whisparr', // Default page to open
    },

    // ========== Infrastructure Services ==========
    // Env: SEERR_ENABLED, SEERR_URL, SEERR_API_KEY, SEERR_ICON_URL
    // Env: BAZARR_ENABLED, BAZARR_URL, BAZARR_API_KEY, BAZARR_ICON_URL
    // Env: TAUTULLI_ENABLED, TAUTULLI_URL, TAUTULLI_API_KEY, TAUTULLI_ICON_URL
    // Env: MAINTAINERR_ENABLED, MAINTAINERR_URL, MAINTAINERR_API_KEY, MAINTAINERR_ICON_URL

    // Seerr: Request Manager
    // Requires: domain_name and redirect_uri for authentication
    // Env: SEERR_ENABLED, SEERR_URL, SEERR_API_KEY, SEERR_ICON_URL
    seerr: {
      enabled: true,
      url: 'http://seerr:5055',
      api_key: 'your-seerr-api-key-here',
      icon_url: '', // URL for alternate Seerr icon
      domain_name: 'seerr.example.com',
      redirect_uri: 'https://seerr.yourdomain.com/oauth2/callback',
    },

    // Bazarr: Subtitle Manager
    // Env: BAZARR_ENABLED, BAZARR_URL, BAZARR_API_KEY, BAZARR_ICON_URL
    bazarr: {
      enabled: true,
      url: 'http://bazarr:6767',
      api_key: 'your-bazarr-api-key-here',
      icon_url: '', // URL for alternate bazarr icon
    },

    // Tautulli: Analytics & Monitoring
    // Env: TAUTULLI_ENABLED, TAUTULLI_URL, TAUTULLI_API_KEY, TAUTULLI_ICON_URL
    tautulli: {
      enabled: true,
      url: 'http://tautulli:8181',
      api_key: 'your-tautulli-api-key-here',
      icon_url: '', // URL for alternate Tautulli icon
    },

    // Maintainerr: Database Maintenance
    // Env: MAINTAINERR_ENABLED, MAINTAINERR_URL, MAINTAINERR_API_KEY, MAINTAINERR_ICON_URL
    maintainerr: {
      enabled: false,
      url: 'http://maintainerr:6246',
      api_key: 'your-maintainerr-api-key-here',
      icon_url: '', // URL for alternate Maintainerr icon
    },
  },
}
