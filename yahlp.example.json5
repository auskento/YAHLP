// YAHLP Configuration (JSON5 format)
// Copy this to yahlp.json5 and customize for your setup
// Environment variables (-e) override these settings

{
  // Access mode: 'public' (HTTPS + Let's Encrypt) or 'private' (HTTP)
  access: {
    mode: 'public',
    type: 'none',  // 'none', 'basic', 'google', 'entra'
  },

  // Domain and email (required for public mode)
  domain: 'yourdomain.com',
  email: 'admin@yourdomain.com',

  // Dashboard settings
  dashboard: {
    name: 'YAHLP',
    style: 'modern',        // 'classic', 'modern', 'sleek', 'minimal'
    color: '#00A99D',
    landing: '',            // Empty = show all services
    order: 'SAB,GET,HYD,TRA,QBI,DEL,PRO,JAC,SON,RAD,LID,WHI,SEE,BAZ,TAU,MNT,JEL,PLX,EMB',
  },

  // Service enable/disable flags
  enabled: {
    sabnzbd: false,
    nzbget: false,
    nzbhydra: false,
    transmission: false,
    qbittorrent: false,
    deluge: false,
    sonarr: false,
    radarr: false,
    lidarr: false,
    whisparr: false,
    prowlarr: false,
    jackett: false,
    seerr: false,
    bazarr: false,
    jellyfin: true,
    emby: false,
    plex: false,
    tautulli: false,
    maintainerr: false,
  },

  // Service URLs
  url: {
    sabnzbd: 'http://sabnzbd:8080',
    nzbget: 'http://nzbget:6789',
    nzbhydra: 'http://nzbhydra:5076',
    transmission: 'http://transmission:9091',
    qbittorrent: 'http://qbittorrent:8080',
    deluge: 'http://deluge:8112',
    sonarr: 'http://sonarr:8989',
    radarr: 'http://radarr:7878',
    lidarr: 'http://lidarr:8686',
    whisparr: 'http://whisparr:6969',
    prowlarr: 'http://prowlarr:9696',
    jackett: 'http://jackett:9117',
    seerr: 'http://seerr:5055',
    bazarr: 'http://bazarr:6767',
    jellyfin: 'http://jellyfin:8096',
    emby: 'http://emby:8096',
    plex: 'http://plex:32400',
    tautulli: 'http://tautulli:8181/tautulli',
    maintainerr: 'http://maintainerr:6246',
  },

  // API Keys for services that require them
  api_key: {
    sabnzbd: '',
    nzbhydra: '',
    sonarr: '',
    radarr: '',
    lidarr: '',
    whisparr: '',
    prowlarr: '',
    jackett: '',
    seerr: '',
    bazarr: '',
    jellyfin: '',
    emby: '',
    plex: '',
    tautulli: '',
    maintainerr: '',
    qbittorrent: '',
  },

  // Usernames (for services that use them)
  username: {
    nzbget: '',
  },

  // Passwords (for services that use them)
  password: {
    nzbget: '',
    transmission: '',
    deluge: '',
  },

  // Custom icon URLs (optional - leave empty for built-in icons)
  icon_url: {
    sabnzbd: '',
    nzbget: '',
    nzbhydra: '',
    transmission: '',
    qbittorrent: '',
    deluge: '',
    sonarr: '',
    radarr: '',
    lidarr: '',
    whisparr: '',
    prowlarr: '',
    jackett: '',
    seerr: '',
    bazarr: '',
    jellyfin: '',
    emby: '',
    plex: '',
    tautulli: '',
    maintainerr: '',
  },

  // Landing pages for services (e.g., 'sonarr/calendar')
  landing: {
    sonarr: '',
    radarr: '',
    whisparr: '',
  },

  // OAuth redirect URIs (for services with OAuth)
  redirect_uri: {
    seerr: 'https://yourdomain.com/seerr/oauth2callback',
    emby: 'https://yourdomain.com/emby/oauth2callback',
    plex: 'https://yourdomain.com/plex/oauth2callback',
  },

  // Custom internal websites to display on the dashboard
  // Sites are shortcuts to other web services and tools available on your network
  // They appear as additional links in the service menu alongside the standard services
  sites: [
    // { name: 'Router', url: 'http://192.168.1.1' },
    // { name: 'NAS', url: 'http://nas.local' },
    // { name: 'Grafana', url: 'http://grafana.local:3000' },
    // { name: 'Portainer', url: 'http://portainer.local:9000' },
  ],
}
