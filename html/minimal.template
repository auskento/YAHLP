<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>@@DASHBOARD_NAME@@ - Status</title>
<script crossorigin src="/react.production.min.js"></script>
<script crossorigin src="/react-dom.production.min.js"></script>
<script src="support.js"></script>
<style>
:root {
  --bg-primary: #08090c;
  --bg-secondary: @@DASHBOARD_COLOR@@;
  --text-primary: #e9ecf2;
  --text-secondary: #5d6575;
  --text-accent: #6b7385;
  --text-link: #4a9eff;
  --border-color: rgba(255, 255, 255, 0.05);
  --border-light: rgba(255, 255, 255, 0.1);
  --status-success: #10b981;
  --status-error: #ef4444;
}

[data-theme="light"] {
  --bg-primary: #f5f5f7;
  --bg-secondary: #ffffff;
  --text-primary: #1a1a1a;
  --text-secondary: #666;
  --text-accent: #4b5263;
  --text-link: #0066cc;
  --border-color: rgba(0, 0, 0, 0.08);
  --border-light: rgba(0, 0, 0, 0.1);
}

[data-theme="light"] img {
  filter: invert(0.85) hue-rotate(180deg) brightness(0.95);
}

* { margin:0; padding:0; box-sizing:border-box; }
body { font-family:system-ui,sans-serif; background:var(--bg-primary); color:var(--text-primary); overflow:hidden; }
a { text-decoration:none; color:inherit; }

.service-link {
  cursor: pointer;
  border: 0;
  padding: 0;
  background: transparent;
  transition: transform .2s, filter .2s;
  border-radius: 14px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  position: relative;
}
.service-link:hover {
  transform: scale(1.1);
  filter: brightness(1.3);
}

:root {
  --icon-multiplier: @@ICON_SIZE@@;
  --gap-multiplier: @@ICON_GAP@@;
  --logo-multiplier: @@LOGO_SIZE@@;
  --base-icon-size: calc(40px * var(--icon-multiplier));
  --base-gap: calc(8px * var(--gap-multiplier));
  --base-logo: calc(36px * var(--logo-multiplier));
}

.service-icon {
  width: var(--base-icon-size);
  height: var(--base-icon-size);
  border-radius: 10px;
  background: rgba(255,255,255,.05);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-shadow: inset 0 0 0 1px rgba(255,255,255,.08);
  transition: box-shadow .2s, width .3s, height .3s;
  border: 2px solid transparent;
  flex-shrink: 0;
  position: relative;
}
.service-link:hover .service-icon {
  box-shadow: inset 0 0 0 2px var(--accent), 0 0 12px var(--accent)66;
}
.service-icon img {
  width: 80%;
  height: 80%;
  object-fit: contain;
}

.tooltip {
  visibility: hidden;
  position: absolute;
  bottom: 110%;
  left: 50%;
  transform: translateX(-50%);
  background-color: rgba(0, 0, 0, 0.9);
  color: var(--text-primary);
  padding: 8px 12px;
  border-radius: 6px;
  white-space: nowrap;
  font-size: 11px;
  z-index: 1000;
  border: 1px solid var(--border-light);
  opacity: 0;
  transition: opacity 0.2s;
}
.service-link:hover .tooltip {
  visibility: visible;
  opacity: 1;
}

.tooltip-status {
  font-size: 10px;
  color: var(--text-secondary);
}

.site-link {
  cursor: pointer;
  border: 0;
  padding: 0;
  background: transparent;
  transition: transform .2s, filter .2s;
  border-radius: 10px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}
.site-link:hover {
  transform: scale(1.1);
  filter: brightness(1.3);
}
.site-icon {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  background: rgba(255,255,255,.05);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-shadow: inset 0 0 0 1px rgba(255,255,255,.08);
}
.site-icon img {
  width: 80%;
  height: 80%;
  object-fit: contain;
}
.site-code {
  display: none;
}

.service-card {
  background: rgba(255,255,255,.03);
  border: 1px solid var(--border-color);
  border-radius: 10px;
  padding: 14px;
  margin-bottom: 10px;
  transition: all 0.2s;
}
.service-card:hover {
  background: rgba(255,255,255,.06);
  border-color: var(--border-light);
}
.service-name {
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 8px;
  display: flex;
  align-items: center;
  gap: 6px;
}
.status-indicator {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}
.status-online {
  background-color: var(--status-success);
  animation: pulse 2s infinite;
}
.status-offline {
  background-color: var(--status-error);
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}
.service-stats {
  color: var(--text-secondary);
  font-size: 12px;
  line-height: 1.6;
}
</style>
</head>
<body style="display:flex;height:100vh;width:100vw;background:radial-gradient(1200px 700px at 18% -10%,rgba(58,160,224,.10),transparent 60%),radial-gradient(900px 600px at 100% 110%,rgba(46,205,111,.07),transparent 55%),#08090c;overflow:hidden">

  <aside style="display:flex;flex-direction:column;align-items:center;gap:calc(8px * var(--gap-multiplier));padding:15px 10px;flex:none;width:calc(60px * var(--icon-multiplier));min-width:60px;border-right:1px solid var(--border-color);overflow-y:auto;overflow-x:hidden;background:var(--bg-secondary)">

    <div style="display:flex;flex-direction:column;align-items:center;gap:3px;flex-shrink:0">
      <a href="/" style="display:flex;align-items:center;justify-content:center;text-decoration:none;cursor:pointer">
        <img src="@@DASHBOARD_ICON@@" alt="Dashboard" style="width:var(--base-logo);height:var(--base-logo);object-fit:contain;filter:drop-shadow(0 4px 16px rgba(58,160,224,.4));transition:width .3s,height .3s">
      </a>
      <div style="text-align:center">
        <div style="font-size:10px;color:#6b7385;letter-spacing:.05em;word-break:break-word;max-width:80px">@@DASHBOARD_NAME@@</div>
      </div>
    </div>

    <nav id="services-nav" style="display:flex;flex-direction:column;gap:var(--base-gap);align-items:center;overflow-y:auto;flex:1;width:100%;padding-right:4px;transition:gap .3s">
      <!-- Services injected here -->
    </nav>

    <div style="width:1px;height:10px;background:rgba(255,255,255,.1);flex-shrink:0"></div>

    @@STYLE_SWITCHER@@

  </aside>

  <main style="flex:1;min-width:0;position:relative;display:flex;flex-direction:column;overflow:auto;padding:20px">
    <div id="dashboard-content">
      <div style="text-align:center;color:var(--text-secondary);padding:40px">Loading service status...</div>
    </div>
  </main>

  <aside style="display:flex;flex-direction:column;align-items:center;gap:8px;padding:15px 8px;flex:none;width:60px;border-left:1px solid var(--border-color);overflow-y:auto;background:var(--bg-secondary)">
    @@SITES_ITEMS@@
  </aside>

</div>

<script>
const SERVICES = @@SERVICES_ARRAY@@;
const nav = document.getElementById('services-nav');
const content = document.getElementById('dashboard-content');

const codeToService = {
    'jel': 'jellyfin', 'pls': 'plex', 'emb': 'emby',
    'son': 'sonarr', 'rad': 'radarr', 'liz': 'lidarr', 'wis': 'whisparr',
    'qbt': 'qbittorrent', 'sab': 'sabnzbd', 'nzb': 'nzbget', 'tra': 'transmission', 'del': 'deluge',
    'hyd': 'nzbhydra', 'pro': 'prowlarr', 'see': 'seerr', 'baz': 'bazarr', 'tau': 'tautulli', 'mai': 'maintainerr'
};

// Render service icons
SERVICES.forEach(app => {
    const btn = document.createElement('button');
    btn.className = 'service-link';
    btn.style.setProperty('--accent', app.accent);

    btn.innerHTML = `
      <div class="service-icon">
        <img src="${app.icon}" alt="${app.name}" />
      </div>
      <div class="tooltip">
        <div>${app.name}</div>
        <div class="tooltip-status" style="margin-top:4px;font-weight:500" data-code="${app.code}">Loading...</div>
      </div>
    `;
    nav.appendChild(btn);
});

const apiBase = `http://${window.location.hostname}:3000/api`;

async function fetchServiceStatus(service, app) {
    try {
        let url, method = 'GET';
        if (['jellyfin', 'plex', 'emby'].includes(service)) {
            url = `${apiBase}/${service}/info`;
        } else if (['sonarr', 'radarr', 'lidarr', 'whisparr'].includes(service)) {
            url = `${apiBase}/${service}/queue`;
        } else if (['qbittorrent', 'sabnzbd'].includes(service)) {
            url = `${apiBase}/${service}/stats`;
        } else if (['nzbget', 'transmission', 'deluge'].includes(service)) {
            url = `${apiBase}/${service}/stats`;
            method = 'POST';
        } else if (['nzbhydra', 'prowlarr', 'seerr', 'bazarr', 'tautulli', 'maintainerr'].includes(service)) {
            url = `${apiBase}/${service}/status`;
        } else {
            return null;
        }

        const response = await fetch(url, { mode: 'cors', redirect: 'follow', method });
        if (!response.ok) throw new Error(`HTTP ${response.status}`);

        const data = await response.json();
        if (!data) return null;

        let stats = [];
        if (service === 'jellyfin' || service === 'plex' || service === 'emby') {
            const sessions = Array.isArray(data) ? data : data.MediaSessions || [];
            const playing = sessions.filter(s => s.PlayState && !s.PlayState.IsPaused).length;
            stats = [{ label: 'Playing', value: playing }];
        } else if (['sonarr', 'radarr', 'lidarr', 'whisparr'].includes(service)) {
            stats = [
                { label: 'Queue', value: data.queue || 0 },
                { label: 'Downloading', value: data.downloading || 0 },
                { label: 'Completed', value: data.completed || 0 }
            ];
        } else if (service === 'qbittorrent') {
            stats = [
                { label: 'Queue', value: data.total || 0 },
                { label: 'Speed', value: `${data.dlSpeed || 0} MB/s` }
            ];
        } else if (service === 'transmission') {
            stats = [{ label: 'Speed', value: `${data.dlSpeed || 0} MB/s` }];
        } else if (service === 'sabnzbd') {
            stats = [
                { label: 'Queue', value: data.queue || 0 },
                { label: 'Speed', value: `${data.dlSpeed || 0} MB/s` }
            ];
        } else if (service === 'nzbget') {
            stats = [{ label: 'Downloading', value: data.downloading || 0 }];
        } else if (service === 'deluge') {
            stats = [
                { label: 'Downloading', value: data.downloading || 0 },
                { label: 'Speed', value: `${data.dlSpeed || 0} MB/s` }
            ];
        } else if (service === 'tautulli') {
            stats = [
                { label: 'Top User', value: data.topUser || 'N/A' },
                { label: 'Users', value: data.users || 0 },
                { label: 'Libraries', value: data.libraries || 0 }
            ];
        }

        return { ...app, status: 'Online', stats };
    } catch (err) {
        console.error(`[${service}] Error:`, err);
        return { ...app, status: 'Offline', stats: [] };
    }
}

async function loadDashboard() {
    const statuses = await Promise.all(SERVICES.map(app => fetchServiceStatus(codeToService[app.code] || app.code, app)));

    // Update tooltips
    const tooltips = document.querySelectorAll('[data-code]');
    tooltips.forEach((tooltip, idx) => {
        if (statuses[idx]) {
            const status = statuses[idx].status;
            tooltip.textContent = status;
            tooltip.style.color = status === 'Online' ? 'var(--status-success)' : 'var(--status-error)';
        }
    });

    // Update main dashboard
    let html = '';
    statuses.forEach(status => {
        if (!status) return;
        const statusClass = status.status === 'Online' ? 'status-online' : 'status-offline';
        html += `
            <div class="service-card">
                <div class="service-name">
                    <span class="status-indicator ${statusClass}"></span>
                    ${status.name} <span style="color:var(--text-secondary);font-size:11px">${status.status}</span>
                </div>
                <div class="service-stats">
                    ${status.stats.map(s => `<div>${s.label}: <strong>${s.value}</strong></div>`).join('')}
                </div>
            </div>
        `;
    });

    content.innerHTML = html || '<div style="text-align:center;color:var(--text-secondary)">No services available</div>';
}

loadDashboard();
setInterval(loadDashboard, 30000);

// Hide sites sidebar if empty
const rightSidebar = document.querySelector('aside:nth-of-type(2)');
if (rightSidebar && rightSidebar.children.length === 0) {
    rightSidebar.style.display = 'none';
}

// Site link handling
document.querySelectorAll('.site-link').forEach(link => {
    link.addEventListener('click', function(e) {
        e.preventDefault();
        window.open(this.href, '_blank');
    });
});

// Theme management
(function() {
    const defaultTheme = '@@DASHBOARD_THEME@@' || 'dark';
    const savedTheme = localStorage.getItem('theme') || defaultTheme;
    document.documentElement.setAttribute('data-theme', savedTheme);

    const themeButton = document.getElementById('theme-toggle-minimal');
    if (themeButton) {
        themeButton.textContent = savedTheme === 'dark' ? '☀️' : '🌙';
        themeButton.addEventListener('click', function() {
            const current = document.documentElement.getAttribute('data-theme');
            const next = current === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('theme', next);
            themeButton.textContent = next === 'dark' ? '☀️' : '🌙';
        });
    }
})();
</script>
</body>
</html>
