<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <title>@@DASHBOARD_NAME@@</title>
    <style>
        :root {
            --bg-primary: #000;
            --bg-secondary: #1a1a1a;
            --text-primary: #fff;
            --text-secondary: #888;
            --text-accent: #4a9eff;
            --border-color: #444;
        }

        [data-theme="light"] {
            --bg-primary: #f5f5f7;
            --bg-secondary: #ffffff;
            --text-primary: #1a1a1a;
            --text-secondary: #666;
            --text-accent: #0066cc;
            --border-color: #d0d0d0;
        }

        [data-theme="light"] img {
            filter: invert(0.85) hue-rotate(180deg) brightness(0.95);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background-color: var(--bg-primary);
            color: var(--text-primary);
            padding-bottom: 60px;
        }

        .header {
            background-color: var(--bg-secondary);
            padding: 12px 16px;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 8px;
            flex: 1;
            min-width: 0;
        }

        .header-left img {
            width: 28px;
            height: 28px;
            object-fit: contain;
        }

        .header-left span {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-primary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .header-right {
            display: flex;
            gap: 8px;
        }

        button {
            background: none;
            border: none;
            cursor: pointer;
            font-size: 18px;
            padding: 4px;
            color: var(--text-accent);
        }

        .health-indicator {
            display: flex;
            align-items: center;
            gap: 4px;
            font-size: 11px;
            color: var(--text-secondary);
            position: relative;
            cursor: pointer;
        }

        .health-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #4caf50;
            box-shadow: 0 0 4px #4caf50;
        }

        .health-tooltip {
            display: none;
            position: absolute;
            top: 100%;
            right: 0;
            background: var(--bg-primary);
            border: 1px solid var(--border-color);
            border-radius: 4px;
            padding: 8px 12px;
            margin-top: 8px;
            font-size: 11px;
            white-space: nowrap;
            z-index: 1000;
            min-width: 150px;
        }

        .health-tooltip.show {
            display: block;
        }

        .services-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            padding: 16px;
        }

        .service-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            color: inherit;
            padding: 12px;
            border-radius: 8px;
            border: 0.5px solid var(--border-color);
            background: var(--bg-secondary);
            transition: all 0.2s;
        }

        .service-item:active {
            transform: scale(0.95);
            background: var(--bg-secondary);
            border-color: var(--text-accent);
        }

        .service-icon {
            width: 48px;
            height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .service-icon img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }

        .service-name {
            font-size: 11px;
            text-align: center;
            color: var(--text-secondary);
            line-height: 1.2;
            word-break: break-word;
        }

        .section-title {
            font-size: 12px;
            font-weight: 600;
            color: var(--text-secondary);
            padding: 12px 16px 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .sites-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 8px;
            padding: 0 16px 16px;
        }

        .site-link {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            text-decoration: none;
            padding: 8px;
            border-radius: 6px;
            border: 0.5px solid var(--border-color);
            background: var(--bg-secondary);
            transition: all 0.2s;
        }

        .site-link:active {
            transform: scale(0.95);
            border-color: var(--text-accent);
        }

        .site-icon {
            width: 32px;
            height: 32px;
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--bg-primary);
            overflow: hidden;
        }

        .site-icon img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            padding: 2px;
        }

        .site-code {
            display: none;
        }

        iframe {
            display: none;
        }

        @supports (padding: max(0px)) {
            body {
                padding-bottom: max(60px, env(safe-area-inset-bottom));
            }

            .header {
                padding-left: max(16px, env(safe-area-inset-left));
                padding-right: max(16px, env(safe-area-inset-right));
                padding-top: max(12px, env(safe-area-inset-top));
            }
        }
    </style>
</head>
<body>

<div class="header">
    <div class="header-left">
        <img src="@@DASHBOARD_ICON@@" alt="Dashboard">
        <span>@@DASHBOARD_NAME@@</span>
        <div class="health-indicator" id="health-status">
            <div class="health-dot" id="health-dot"></div>
            <span id="health-text">●</span>
            <div class="health-tooltip" id="health-tooltip">
                <div id="health-details"></div>
            </div>
        </div>
    </div>
    <div class="header-right">
        <button id="theme-toggle" title="Toggle theme">☀️</button>
    </div>
</div>

<div class="section-title">Services</div>
<div class="services-grid">
    @@MENU_ITEMS@@
</div>

<div class="sites-section" style="display: none;">
    <div class="section-title">Sites</div>
    <div class="sites-grid">
        @@SITES_ITEMS@@
    </div>
</div>

<script>
    function updateTheme() {
        const themeButton = document.getElementById('theme-toggle');
        const savedTheme = localStorage.getItem('theme') || 'dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
        themeButton.textContent = savedTheme === 'dark' ? '☀️' : '🌙';
    }

    updateTheme();

    document.getElementById('theme-toggle').addEventListener('click', function() {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        updateTheme();
    });

    // Service popup handling
    document.querySelectorAll('.service-item').forEach(link => {
        link.addEventListener('click', function(e) {
            if (this.href.startsWith('http')) {
                e.preventDefault();
                window.open(this.href, 'popup_' + Date.now(), 'width=1200,height=800,resizable=yes');
            }
        });
    });

    // Show sites section only if there are sites (check for child elements)
    const sitesSection = document.querySelector('.sites-section');
    const sitesGrid = document.querySelector('.sites-grid');
    if (sitesGrid && sitesGrid.children.length > 0) {
        if (sitesSection) {
            sitesSection.style.display = 'block';
        }
    }

    // Site link handling
    document.querySelectorAll('.site-link').forEach(link => {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            window.open(this.href, '_blank');
        });
    });

    // Service health check for mobile
    function checkServices() {
        const serviceLinks = Array.from(document.querySelectorAll('.service-item')).map(el => ({
            href: el.getAttribute('href'),
            text: el.textContent.trim()
        })).filter(s => s.href && s.href.startsWith('/'));

        if (serviceLinks.length === 0) return;

        const health = {};
        let checkCount = 0;

        serviceLinks.forEach(service => {
            const controller = new AbortController();
            const timeoutId = setTimeout(() => controller.abort(), 30000);

            // Try HEAD first, then GET if HEAD fails
            fetch(service.href, { method: 'HEAD', signal: controller.signal })
                .then(response => {
                    clearTimeout(timeoutId);
                    // Mark online if 2xx, 3xx, or auth errors (401, 403)
                    // Mark offline for 5xx server errors
                    if (response.status < 400 || response.status === 401 || response.status === 403) {
                        health[service.href] = 'online';
                    } else {
                        health[service.href] = 'offline';
                    }
                    checkCount++;
                    if (checkCount === serviceLinks.length) {
                        updateHealthDisplay(health, serviceLinks);
                    }
                })
                .catch(() => {
                    // HEAD failed, try GET
                    const getController = new AbortController();
                    const getTimeoutId = setTimeout(() => getController.abort(), 30000);

                    fetch(service.href, { method: 'GET', signal: getController.signal })
                        .then(response => {
                            clearTimeout(getTimeoutId);
                            // Mark online if 2xx, 3xx, or auth errors (401, 403)
                            // Mark offline for 5xx server errors
                            if (response.status < 400 || response.status === 401 || response.status === 403) {
                                health[service.href] = 'online';
                            } else {
                                health[service.href] = 'offline';
                            }
                        })
                        .catch(() => {
                            clearTimeout(getTimeoutId);
                            // Both requests failed - service is offline
                            health[service.href] = 'offline';
                        })
                        .finally(() => {
                            checkCount++;
                            if (checkCount === serviceLinks.length) {
                                updateHealthDisplay(health, serviceLinks);
                            }
                        });
                });
        });
    }

    function updateHealthDisplay(health, services) {
        const offlineCount = Object.values(health).filter(s => s === 'offline').length;
        const healthDot = document.getElementById('health-dot');
        const healthText = document.getElementById('health-text');
        const healthDetails = document.getElementById('health-details');

        const offlineServices = Object.entries(health)
            .filter(([_, status]) => status === 'offline')
            .map(([href, _]) => {
                const service = services.find(s => s.href === href);
                return service ? service.text : href;
            });

        if (offlineCount === 0) {
            healthDot.style.background = '#4caf50';
            healthDot.style.boxShadow = '0 0 4px #4caf50';
            healthText.textContent = '●';
            healthDetails.textContent = 'All systems operational';
        } else {
            healthDot.style.background = '#ff6b6b';
            healthDot.style.boxShadow = '0 0 4px #ff6b6b';
            healthText.textContent = '●';
            healthDetails.innerHTML = '<div style="text-align:left"><strong>Offline:</strong><br>' +
                offlineServices.map(s => '• ' + s).join('<br>') + '</div>';
        }
    }

    checkServices();
    setInterval(checkServices, 30000);

    // Health status tooltip toggle
    const healthStatus = document.getElementById('health-status');
    const healthTooltip = document.getElementById('health-tooltip');
    if (healthStatus && healthTooltip) {
        healthStatus.addEventListener('click', () => {
            healthTooltip.classList.toggle('show');
        });
        document.addEventListener('click', (e) => {
            if (!healthStatus.contains(e.target)) {
                healthTooltip.classList.remove('show');
            }
        });
    }
</script>

</body>
</html>
