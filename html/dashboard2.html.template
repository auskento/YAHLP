<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Dashboard - Icons Only</title>
</head>
<body style="margin:0;height:100%;background:#08090c;font-family:system-ui,sans-serif">
<div id="container" style="display:flex;height:100vh;width:100vw;color:#e9ecf2;background:radial-gradient(1200px 700px at 18% -10%,rgba(58,160,224,.10),transparent 60%),radial-gradient(900px 600px at 100% 110%,rgba(46,205,111,.07),transparent 55%),#08090c;overflow:hidden;align-items:center;justify-content:center">

  <aside id="sidebar" style="display:flex;flex-direction:column;align-items:center;gap:24px;padding:40px 30px;max-height:100%;overflow-y:auto">

    <div style="display:flex;flex-direction:column;align-items:center;gap:6px">
      <div style="width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,#3aa0e0,#2ecd6f);display:flex;align-items:center;justify-content:center;box-shadow:0 4px 16px rgba(58,160,224,.4)">
        <div style="width:18px;height:18px;border:3px solid #08090c;border-radius:5px"></div>
      </div>
      <div style="text-align:center">
        <div style="font-size:13px;color:#6b7385;letter-spacing:.08em">MEDIA</div>
      </div>
    </div>

    <nav id="services-nav" style="display:flex;flex-direction:column;gap:20px;align-items:center">
      <!-- Services buttons injected here -->
    </nav>

    <div style="width:1px;height:20px;background:rgba(255,255,255,.1)"></div>

    <div style="text-align:center;font-size:11px;color:#5d6575">
      <span style="display:block;width:8px;height:8px;border-radius:50%;background:#2ecd6f;margin:0 auto 6px;box-shadow:0 0 8px #2ecd6f;animation:floatGlow 2.6s ease-in-out infinite"></span>
      Online
    </div>

  </aside>

  <main style="flex:1;min-width:0;position:relative">
    <iframe id="content-frame" name="Main" title="App" style="position:absolute;inset:0;width:100%;height:100%;border:0;background:#0b0d11"></iframe>

    <div id="welcome-screen" style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:40px;background:radial-gradient(900px 600px at 50% 30%,rgba(58,160,224,.08),transparent 60%),#0b0d11">
      <div style="width:64px;height:64px;border-radius:18px;background:linear-gradient(135deg,#3aa0e0,#2ecd6f);display:flex;align-items:center;justify-content:center;box-shadow:0 10px 40px rgba(58,160,224,.35);margin-bottom:26px">
        <div style="width:22px;height:22px;border:3px solid #0b0d11;border-radius:6px"></div>
      </div>
      <div style="font-weight:600;font-size:27px;color:#f4f6fa;letter-spacing:-.01em">Welcome</div>
      <div style="font-size:15px;color:#828b9c;margin-top:10px;max-width:380px;line-height:1.55">Click an icon to open a service</div>
    </div>
  </main>
</div>

<style>
  @keyframes floatGlow { 0%,100%{opacity:.55} 50%{opacity:.95} }
  .service-btn { 
    cursor:pointer; 
    border:0; 
    padding:0; 
    background:transparent; 
    transition:transform .2s,filter .2s; 
    border-radius:14px;
  }
  .service-btn:hover { 
    transform:scale(1.1); 
    filter:brightness(1.3);
  }
  .service-icon {
    width:60px;
    height:60px;
    flex:none;
    border-radius:14px;
    background:rgba(255,255,255,.05);
    display:flex;
    align-items:center;
    justify-content:center;
    overflow:hidden;
    box-shadow:inset 0 0 0 1px rgba(255,255,255,.08);
    transition:box-shadow .2s;
    border:2px solid transparent;
  }
  .service-btn:hover .service-icon {
    box-shadow:inset 0 0 0 2px var(--accent), 0 0 16px var(--accent)66;
  }
  .service-btn.active .service-icon {
    box-shadow:inset 0 0 0 2px var(--accent), 0 0 16px var(--accent)66;
  }
  .service-icon img {
    width: 40px;
    height: 40px;
    object-fit: contain;
  }
</style>

<script>
  const SERVICES = @@SERVICES_ARRAY@@;
  const frame = document.getElementById('content-frame');
  const welcome = document.getElementById('welcome-screen');
  const nav = document.getElementById('services-nav');
  let activeId = null;

  function navigate(app) {
    if (app.popup) {
      window.open(app.href, app.name, 'resizable=no,status=no,location=no,toolbar=no,menubar=no,scrollbars=no');
      return;
    }
    
    // Hide welcome, show frame
    welcome.style.display = 'none';
    
    // Update active state
    document.querySelectorAll('.service-btn').forEach(btn => {
      if (btn.dataset.id === app.id) {
        btn.classList.add('active');
      } else {
        btn.classList.remove('active');
      }
    });
    
    activeId = app.id;
    frame.src = app.href;
  }

  // Render services
  SERVICES.forEach(app => {
    const btn = document.createElement('button');
    btn.className = 'service-btn';
    btn.dataset.id = app.id;
    btn.title = app.name;
    btn.style.setProperty('--accent', app.accent);
    btn.onclick = () => navigate(app);
    
    btn.innerHTML = `
      <div class="service-icon">
        <img src="${app.icon}" alt="${app.name}" />
      </div>
    `;
    
    nav.appendChild(btn);
  });
</script>
</body>
</html>
