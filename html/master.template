<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>@@DASHBOARD_NAME@@ - Status</title>
<script crossorigin src="/react.production.min.js"></script>
<script crossorigin src="/react-dom.production.min.js"></script>
<script src="support.js"></script>
<link rel="stylesheet" href="/styles/base.css">
<link rel="stylesheet" href="/styles/layout-@@TEMPLATE_TYPE@@.css">
<style>
@@DASHBOARD_COLOR_OVERRIDE@@

/* Dynamic icon sizing */
:root {
    --dynamic-icon-size: 100px;
}

.service-card-icon img,
.menu-icon,
.service-icon-only img {
    max-width: var(--dynamic-icon-size);
    max-height: var(--dynamic-icon-size);
    width: 100%;
    height: 100%;
    object-fit: contain;
    image-rendering: crisp-edges;
}

/* Smooth transitions when resizing */
.service-card-icon img,
.service-icon-only img {
    transition: width 0.3s ease, height 0.3s ease;
}
</style>
<script>
// Set dashboard lock state if DASHBOARD_STYLE=style:only is used
if (@@DASHBOARD_LOCKED@@) {
    localStorage.setItem('dashboard-locked', 'true');
}

// Immediately calculate average color for content panel
document.addEventListener('DOMContentLoaded', function() {
    const styleTag = document.querySelector('style');
    const dashContentEl = document.getElementById('dashboard-content');

    if (styleTag && dashContentEl) {
        const match = styleTag.textContent.match(/--dashboard-color:\s*([#\w]+)/);
        if (match) {
            const dashColor = match[1];
            const dashRgb = {
                r: parseInt(dashColor.substring(1, 3), 16),
                g: parseInt(dashColor.substring(3, 5), 16),
                b: parseInt(dashColor.substring(5, 7), 16)
            };
            const bgRgb = { r: 8, g: 9, b: 12 }; // #08090c
            const avgRgb = {
                r: Math.round((dashRgb.r + bgRgb.r) / 2),
                g: Math.round((dashRgb.g + bgRgb.g) / 2),
                b: Math.round((dashRgb.b + bgRgb.b) / 2)
            };
            const avgHex = '#' + [avgRgb.r, avgRgb.g, avgRgb.b]
                .map(x => x.toString(16).padStart(2, '0'))
                .join('');

            // Set inline style directly on the element
            dashContentEl.style.backgroundColor = avgHex;
        }
    }
});
</script>
</head>
<body>
<div class="app" data-layout="@@TEMPLATE_TYPE@@" data-theme="dark" style="padding-bottom: 48px;">
  <header class="app-header">
    <a href="/" onclick="return goHome(event)" style="display: flex; align-items: center; gap: 12px; text-decoration: none; cursor: pointer;">
      <img src="@@DASHBOARD_ICON@@" alt="Dashboard" class="logo-img">
      <div class="logo-text">@@DASHBOARD_NAME@@</div>
    </a>
    <div class="header-time">
      <div class="current-time" id="currentTime">--:--</div>
      <div class="current-date" id="currentDate">---</div>
    </div>
  </header>

  <aside class="app-sidebar">
    <nav class="service-menu" id="serviceMenu">
      <!-- Services populated by JavaScript -->
    </nav>
    <div id="sidebar-sites-section" class="sidebar-sites-section" style="display:none">
      <div id="sidebar-sites-grid" class="sidebar-sites-grid">
        <!-- Sites populated by JavaScript for sidebar layouts -->
      </div>
    </div>
  </aside>

  <main class="app-content">
    <iframe id="service-frame" class="service-frame" src="" title="Service"></iframe>

    <div id="dashboard-view" class="dashboard-view">
      <div class="dashboard-header">
        <h1 class="dashboard-title">Service Status</h1>
        <p class="dashboard-subtitle">Real-time data from your services</p>
      </div>
      <div id="dashboard-content" class="dashboard-content">
        <div class="loading-placeholder">Loading service status...</div>
      </div>
    </div>

    <div id="welcome-screen" class="welcome-screen" style="display:none">
      <img src="@@DASHBOARD_ICON@@" alt="Dashboard" class="welcome-logo">
      <div class="welcome-title">Welcome to YAHLP</div>
      <div class="welcome-message">
        Configure your services with API keys in the environment variables to get started.
        Once configured, your service status will appear here.
      </div>
    </div>
  </main>

  <div id="sites-section" class="sites-section" style="display:none">
    <div class="sites-title">Quick Links</div>
    <div id="sites-grid" class="sites-grid">
      <!-- Sites populated by JavaScript -->
    </div>
  </div>
</div>

<footer class="app-footer">
  <div class="footer-left">
    <a href="/" onclick="return goHome(event)" style="display: flex; align-items: center; gap: 8px; text-decoration: none; color: inherit; cursor: pointer;">
      <img src="@@DASHBOARD_ICON@@" alt="Dashboard" class="footer-icon">
      <span class="footer-name">@@DASHBOARD_NAME@@</span>
    </a>
  </div>
  <div class="footer-center">
    <input type="range" id="templateSlider" min="0" max="0" value="0" class="template-slider" title="Switch template style">
    <span class="template-label" id="templateLabel">Classic</span>
  </div>
  <div class="footer-right">
    <div class="footer-time">
      <span id="footerTime">--:--</span>
      <span id="footerDate">---</span>
    </div>
    <button id="themeToggle" class="theme-toggle" title="Toggle dark/light mode" aria-label="Toggle dark/light mode">🌙</button>
  </div>
</footer>

<script>
const SERVICES = @@SERVICES_ARRAY@@;
const SITES = @@SITES_ARRAY@@;
const DASHBOARD_LANDING = '@@DASHBOARD_LANDING@@';
const apiBase = `/api`;

const codeToService = {
    'JEL': 'jellyfin', 'PLX': 'plex', 'EMB': 'emby',
    'SON': 'sonarr', 'RAD': 'radarr', 'LID': 'lidarr', 'WHI': 'whisparr',
    'QBI': 'qbittorrent', 'TRA': 'transmission', 'GET': 'nzbget', 'SAB': 'sabnzbd',
    'DEL': 'deluge', 'HYD': 'nzbhydra', 'PRO': 'prowlarr', 'SEE': 'seerr',
    'BAZ': 'bazarr', 'TAU': 'tautulli', 'MNT': 'maintainerr', 'JAC': 'jackett'
};

// Convert icon path to SVG when available, fallback to PNG
function getIconPath(iconPath) {
    if (!iconPath) return iconPath;
    // Replace .png with .svg, keep everything else as-is
    return iconPath.replace(/\.png$/i, '.svg');
}

// Calculate average color between dashboard color and bg-primary
function initDashboardColor() {
    // Wait a moment for styles to be applied
    setTimeout(() => {
        const htmlElement = document.documentElement;
        const computedStyle = window.getComputedStyle(htmlElement);

        // Try to get the dashboard color CSS variable
        let dashboardColor = computedStyle.getPropertyValue('--dashboard-color').trim();

        if (!dashboardColor) {
            // Try to find it in the style tag directly
            const styleTag = document.querySelector('style');
            if (styleTag) {
                const match = styleTag.textContent.match(/--dashboard-color:\s*([#\w]+)/);
                if (match) dashboardColor = match[1];
            }
        }

        if (dashboardColor) {
            const dashRgb = hexToRgb(dashboardColor);
            const bgRgb = hexToRgb('#08090c'); // bg-primary color

            if (dashRgb && bgRgb) {
                // Calculate average color
                const avgRgb = {
                    r: Math.round((dashRgb.r + bgRgb.r) / 2),
                    g: Math.round((dashRgb.g + bgRgb.g) / 2),
                    b: Math.round((dashRgb.b + bgRgb.b) / 2)
                };

                const avgColor = rgbToHex(avgRgb);
                document.documentElement.style.setProperty('--content-bg-color', avgColor);
                return;
            }
        }

        // If all else fails, use bg-secondary as fallback
        document.documentElement.style.setProperty('--content-bg-color', 'var(--bg-secondary)');
    }, 100);
}

function hexToRgb(hex) {
    const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
    return result ? {
        r: parseInt(result[1], 16),
        g: parseInt(result[2], 16),
        b: parseInt(result[3], 16)
    } : null;
}

function rgbToHex(rgb) {
    const toHex = (n) => {
        const hex = n.toString(16);
        return hex.length === 1 ? '0' + hex : hex;
    };
    return `#${toHex(rgb.r)}${toHex(rgb.g)}${toHex(rgb.b)}`;
}

initDashboardColor();

const frame = document.getElementById('service-frame');
const dashboardView = document.getElementById('dashboard-view');
const content = document.getElementById('dashboard-content');
const welcomeScreen = document.getElementById('welcome-screen');
const serviceMenu = document.getElementById('serviceMenu');

function updateDateTime() {
    const now = new Date();
    const timeEl = document.getElementById('currentTime');
    const dateEl = document.getElementById('currentDate');
    if (timeEl) timeEl.textContent = now.toLocaleTimeString('en-AU', {hour: '2-digit', minute: '2-digit'});
    if (dateEl) dateEl.textContent = now.toLocaleDateString('en-AU', {weekday: 'short', month: 'short', day: 'numeric'});
}

updateDateTime();
setInterval(updateDateTime, 1000);

async function fetchServiceStatus(service, app) {
    try {
        // Special handling for maintainerr - needs two endpoints
        if (service === 'maintainerr') {
            const sectionsUrl = `${apiBase}/maintainerr/api/overlays/sections`;
            const sizesUrl = `${apiBase}/maintainerr/api/storage-metrics/library-sizes`;

            const [sectionsResp, sizesResp] = await Promise.all([
                fetch(sectionsUrl, { mode: 'cors', redirect: 'follow' }),
                fetch(sizesUrl, { mode: 'cors', redirect: 'follow' })
            ]);

            if (!sectionsResp.ok || !sizesResp.ok) {
                throw new Error(`HTTP ${sectionsResp.status}/${sizesResp.status}`);
            }

            const sections = await sectionsResp.json();
            const sizes = await sizesResp.json();

            const stats = [];
            if (Array.isArray(sections) && Array.isArray(sizes)) {
                sections.forEach((section, idx) => {
                    const sizeGB = sizes[idx] ? (sizes[idx] / (1024 ** 3)).toFixed(2) : '0.00';
                    stats.push({ label: section, value: `${sizeGB} GB` });
                });
            }

            return { ...app, status: 'Online', stats };
        }

        let url;
        if (service === 'jellyfin' || service === 'emby') {
            url = `${apiBase}/${service}/info`;
        } else if (service === 'plex') {
            url = `${apiBase}/plex/server`;
        } else if (['sonarr', 'radarr', 'lidarr', 'whisparr'].includes(service)) {
            url = `${apiBase}/${service}/queue`;
        } else if (['qbittorrent', 'sabnzbd', 'nzbget', 'transmission', 'deluge'].includes(service)) {
            url = `${apiBase}/${service}/stats`;
        } else if (service === 'nzbhydra') {
            url = `${apiBase}/nzbhydra`;
        } else if (['seerr', 'bazarr', 'tautulli'].includes(service)) {
            url = `${apiBase}/${service}/status`;
        } else if (service === 'prowlarr') {
            url = `${apiBase}/prowlarr/health`;
        } else if (service === 'jackett') {
            url = `${apiBase}/jackett/health`;
        } else {
            return null;
        }

        const response = await fetch(url, { mode: 'cors', redirect: 'follow', method: service === 'nzbget' || service === 'transmission' || service === 'deluge' || service === 'nzbhydra' ? 'POST' : 'GET' });
        if (!response.ok) {
            const errorData = await response.json().catch(() => ({}));
            if (errorData.error && errorData.error.includes('not configured')) {
                return null;
            }
            throw new Error(`HTTP ${response.status}`);
        }

        const data = await response.json();
        if (!data) return null;

        let stats = [];
        if (service === 'jellyfin' || service === 'plex' || service === 'emby') {
            const sessions = Array.isArray(data) ? data : data.MediaSessions || [];
            const playing = sessions.filter(s => s.PlayState && !s.PlayState.IsPaused).length;
            stats = [{ label: 'Playing', value: playing }];
        } else if (service === 'nzbhydra') {
            // NZBHydra doesn't provide useful dashboard stats
            stats = [];
        } else if (['sonarr', 'radarr', 'lidarr', 'whisparr'].includes(service)) {
            stats = [
                { label: 'Queue', value: data.queue || 0 },
                { label: 'Downloading', value: data.downloading || 0 },
                { label: 'Completed', value: data.completed || 0 }
            ];
        } else if (service === 'qbittorrent') {
            stats = [
                { label: 'Queue', value: data.total || 0 },
                { label: 'Speed', value: `${data.dlSpeed || 0} MB/s` }
            ];
        } else if (service === 'transmission') {
            stats = [{ label: 'Speed', value: `${data.dlSpeed || 0} MB/s` }];
        } else if (service === 'sabnzbd') {
            stats = [
                { label: 'Queue', value: data.queue || 0 },
                { label: 'Speed', value: `${data.dlSpeed || 0} MB/s` }
            ];
        } else if (service === 'nzbget') {
            stats = [{ label: 'Downloading', value: data.downloading || 0 }];
        } else if (service === 'deluge') {
            stats = [
                { label: 'Downloading', value: data.downloading || 0 },
                { label: 'Speed', value: `${data.dlSpeed || 0} MB/s` }
            ];
        } else if (service === 'tautulli') {
            stats = [
                { label: 'Top User', value: data.topUser || 'N/A' },
                { label: 'Users', value: data.users || 0 },
                { label: 'Libraries', value: data.libraries || 0 }
            ];
        } else if (service === 'prowlarr') {
            const issues = Array.isArray(data) ? data.length : 0;
            stats = [{ label: 'Health Issues', value: issues }];
        } else if (service === 'jackett') {
            stats = [{ label: 'Results', value: data.results || 0 }];
        }

        return { ...app, status: 'Online', stats };
    } catch (err) {
        console.error(`[${service}] Error:`, err);
        return { ...app, status: 'Offline', stats: [] };
    }
}

function calculateDynamicIconSize() {
    const contentEl = document.getElementById('dashboard-content');
    if (!contentEl) return;

    // Get available width and height
    const rect = contentEl.getBoundingClientRect();
    const availableWidth = rect.width;
    const availableHeight = rect.height;

    // Count visible service cards
    const serviceCards = contentEl.querySelectorAll('.service-card');
    const iconCount = serviceCards.length;

    if (iconCount === 0) return;

    // Calculate optimal icon size based on grid layout
    // Assume responsive grid: ~2 cols mobile, ~3 cols tablet, ~4 cols desktop
    let colsPerRow;
    if (availableWidth < 600) {
        colsPerRow = 1;
    } else if (availableWidth < 1000) {
        colsPerRow = 2;
    } else if (availableWidth < 1400) {
        colsPerRow = 3;
    } else {
        colsPerRow = 4;
    }

    // Calculate rows needed
    const rowsNeeded = Math.ceil(iconCount / colsPerRow);

    // Base margins/padding per card
    const cardPaddingX = 16; // left/right padding
    const cardPaddingY = 16; // top/bottom padding
    const gapBetweenCards = 12; // gap between grid items

    // Available space per card
    const cardWidthAvailable = (availableWidth / colsPerRow) - (gapBetweenCards + cardPaddingX);
    const cardHeightAvailable = (availableHeight / Math.max(rowsNeeded, 2)) - (gapBetweenCards + cardPaddingY);

    // Icon should be ~40-60% of card width/height
    const iconSizeFromWidth = cardWidthAvailable * 0.5;
    const iconSizeFromHeight = cardHeightAvailable * 0.6;

    // Use the smaller to fit both dimensions
    let iconSize = Math.min(iconSizeFromWidth, iconSizeFromHeight);

    // Clamp to reasonable bounds
    iconSize = Math.max(48, Math.min(200, iconSize));

    // Round to nearest multiple of 4 for clean sizing
    iconSize = Math.round(iconSize / 4) * 4;

    // Set CSS variable for icon sizing
    document.documentElement.style.setProperty('--dynamic-icon-size', iconSize + 'px');

    console.log('[Icon Sizing]', {
        availableSpace: `${availableWidth}x${availableHeight}`,
        iconCount,
        colsPerRow,
        rowsNeeded,
        calculatedIconSize: iconSize
    });
}

// Recalculate on window resize
window.addEventListener('resize', () => {
    calculateDynamicIconSize();
});

async function loadDashboard() {
    // Get health status to know which services are configured
    let configuredServices = {};
    try {
        const response = await fetch(`/health`);
        const health = await response.json();
        configuredServices = health.services || {};
    } catch (err) {
        console.warn('[Health Check] Could not verify configured services:', err);
    }

    const app = document.querySelector('.app');
    const layout = app?.getAttribute('data-layout');
    const isFocusLayout = layout === 'focus';

    const statuses = await Promise.all(SERVICES.map(app => {
        const service = codeToService[app.id];
        if (!service) return Promise.resolve(null);

        // Skip unconfigured services - don't fetch status for them
        if (!configuredServices[service]?.configured) {
            return Promise.resolve(null);
        }

        return fetchServiceStatus(service, app);
    }));

    let html = '';

    if (isFocusLayout) {
        // For focus layout: show full panels for configured, icons for unconfigured
        const statusMap = new Map(statuses.filter(s => s).map(s => [s.name.toLowerCase(), s]));

        SERVICES.forEach(app => {
            const service = codeToService[app.id];
            if (!service) return;

            const status = statusMap.get(app.name.toLowerCase());

            if (status) {
                // Configured service - show full panel
                const isOnline = status.status === 'Online';
                const statusClass = isOnline ? 'online' : 'offline';
                html += `
                    <div class="service-card" data-service-href="${status.href}" data-service-popup="${status.popup}" data-service-name="${status.name}">
                        <div class="service-card-header">
                            <div class="service-card-icon">
                                <img src="${getIconPath(status.icon)}" alt="${status.name}" />
                            </div>
                            <div class="service-card-title">${status.name}</div>
                            <div class="service-card-status">
                                <span class="status-dot ${statusClass}"></span>
                                ${status.status}
                            </div>
                        </div>
                        ${status.stats.map(s => `
                            <div class="service-stat">
                                <span class="stat-label">${s.label}</span>
                                <span class="stat-value">${s.value}</span>
                            </div>
                        `).join('')}
                    </div>
                `;
            } else {
                // Unconfigured service - show icon only
                html += `
                    <div class="service-icon-only" data-service-name="${app.name}" data-service-icon="${app.icon}" title="Not configured">
                        <img src="${getIconPath(app.icon)}" alt="${app.name}" />
                    </div>
                `;
            }
        });
    } else {
        // Standard layout: show all services (configured and unconfigured)
        const statusMap = new Map(statuses.filter(s => s).map(s => [s.name.toLowerCase(), s]));

        SERVICES.forEach(app => {
            const service = codeToService[app.id];
            if (!service) return;

            const status = statusMap.get(app.name.toLowerCase());

            if (status) {
                // Configured service - show full panel with status
                const isOnline = status.status === 'Online';
                const statusClass = isOnline ? 'online' : 'offline';
                html += `
                    <div class="service-card" data-service-href="${status.href}" data-service-popup="${status.popup}" data-service-name="${status.name}">
                        <div class="service-card-header">
                            <div class="service-card-icon">
                                <img src="${getIconPath(status.icon)}" alt="${status.name}" />
                            </div>
                            <div class="service-card-title">${status.name}</div>
                            <div class="service-card-status">
                                <span class="status-dot ${statusClass}"></span>
                                ${status.status}
                            </div>
                        </div>
                        ${status.stats.map(s => `
                            <div class="service-stat">
                                <span class="stat-label">${s.label}</span>
                                <span class="stat-value">${s.value}</span>
                            </div>
                        `).join('')}
                    </div>
                `;
            } else {
                // Unconfigured service - show panel with "Not Configured" status
                html += `
                    <div class="service-card service-card-unconfigured" title="Not configured - add API key to enable">
                        <div class="service-card-header">
                            <div class="service-card-icon">
                                <img src="${getIconPath(app.icon)}" alt="${app.name}" />
                            </div>
                            <div class="service-card-title">${app.name}</div>
                            <div class="service-card-status">
                                <span class="status-dot offline"></span>
                                Not Configured
                            </div>
                        </div>
                    </div>
                `;
            }
        });
    }

    content.innerHTML = html || '<div class="no-services">No configured services</div>';

    // Calculate dynamic icon sizing based on available space and icon count
    calculateDynamicIconSize();

    document.querySelectorAll('.service-card').forEach((card) => {
        card.addEventListener('click', async (e) => {
            e.preventDefault();
            const href = card.getAttribute('data-service-href');
            const isPopup = card.getAttribute('data-service-popup') === 'true';
            const serviceName = card.getAttribute('data-service-name');

            // Special handling for Deluge - get session cookie before opening
            if (serviceName === 'Deluge' || href?.includes('8112')) {
                try {
                    const response = await fetch(`/api/deluge/login`);
                    const data = await response.json();
                    if (data.success && data.cookie) {
                        document.cookie = data.cookie + '; path=/';
                    }
                } catch (err) {
                    console.warn('Deluge pre-auth failed:', err);
                }
            }

            if (isPopup) {
                // Open in new window for certain services, new tab for others
                const windowServices = ['qBittorrent', 'Seerr', 'Emby', 'Plex'];
                const openAsWindow = windowServices.includes(serviceName);

                if (openAsWindow) {
                    window.open(href, '_blank', 'popup=yes,width=1400,height=900,resizable=yes,scrollbars=yes');
                } else {
                    window.open(href, '_blank');
                }
            } else {
                frame.src = href;
                frame.style.display = 'block';
                dashboardView.style.display = 'none';
            }
        });
    });
}

async function buildServiceMenu() {
    let html = '';
    SERVICES.forEach(app => {
        // Handle labeled separator
        if (app.id === 'LBL') {
            html += `<div class="menu-separator menu-separator-label">${app.name}</div>`;
            return;
        }
        // Handle separator markers
        if (app.id === 'SEP') {
            html += '<div class="menu-separator menu-separator-invisible"></div>';
            return;
        }
        if (app.id === 'VIS') {
            html += '<div class="menu-separator menu-separator-visible"></div>';
            return;
        }

        html += `
            <button class="menu-item" title="${app.name}" data-href="${app.href}" data-popup="${app.popup}" data-service-name="${app.name}">
                <img src="${getIconPath(app.icon)}" alt="${app.name}" class="menu-icon">
                <span class="menu-label">${app.name}</span>
            </button>
        `;
    });
    serviceMenu.innerHTML = html;

    document.querySelectorAll('.menu-item').forEach(item => {
        item.addEventListener('click', () => {
            const href = item.getAttribute('data-href');
            const isPopup = item.getAttribute('data-popup') === 'true';
            const serviceName = item.getAttribute('data-service-name');
            const app = document.querySelector('.app');
            const isMobile = app.getAttribute('data-layout') === 'mobile';

            if (isMobile || isPopup) {
                // Open in new window for certain services, new tab for others
                const windowServices = ['qBittorrent', 'Seerr', 'Emby', 'Plex'];
                const openAsWindow = windowServices.includes(serviceName);

                if (openAsWindow) {
                    window.open(href, '_blank', 'popup=yes,width=1400,height=900,resizable=yes,scrollbars=yes');
                } else {
                    window.open(href, '_blank');
                }
            } else {
                frame.src = href;
                frame.style.display = 'block';
                dashboardView.style.display = 'none';
            }
        });
    });
}

// A layout is "sidebar-style" if its own CSS shows #sidebar-sites-section
// (e.g. `.sidebar-sites-section { display: flex }`), rather than a hardcoded
// list of layout names — lets custom layouts opt in without editing this file.
function isSidebarStyleLayout() {
    const section = document.getElementById('sidebar-sites-section');
    if (!section) return false;
    const inlineDisplay = section.style.display;
    section.style.display = '';
    const cssDisplay = getComputedStyle(section).display;
    section.style.display = inlineDisplay;
    return cssDisplay !== 'none';
}

async function buildSitesGrid() {
    const app = document.querySelector('.app');
    const layout = app.getAttribute('data-layout');
    const isMobile = layout === 'mobile';
    const isFocusLayout = layout === 'focus';
    const isSidebarLayout = isSidebarStyleLayout();

    let sites = [];

    // Fetch sites from API configuration
    try {
        const response = await fetch(`${apiBase}/config/sites`);
        if (response.ok) {
            sites = await response.json();
        }
    } catch (err) {
        console.error('[Sites] Error fetching sites:', err);
    }

    if (!sites || sites.length === 0) {
        document.getElementById('sites-section')?.style.display && (document.getElementById('sites-section').style.display = 'none');
        document.getElementById('sidebar-sites-section')?.style.display && (document.getElementById('sidebar-sites-section').style.display = 'none');
        return;
    }

    let html = '';
    sites.forEach((site) => {
        // Transform API format (url) to internal format (href)
        const href = site.url || site.href || '#';
        // Use data attributes to track popup and href for click handlers
        html += `
            <a href="javascript:void(0)" class="site-link" data-popup="${site.popup || isMobile}" data-href="${href}" title="${site.name}">
                <div class="site-icon">
                    <img src="${site.icon}" alt="${site.name}">
                </div>
                <div class="site-name">${site.name}</div>
            </a>
        `;
    });

    if (isSidebarLayout && !isFocusLayout) {
        const sidebarSitesGrid = document.getElementById('sidebar-sites-grid');
        const sidebarSitesSection = document.getElementById('sidebar-sites-section');
        sidebarSitesGrid.innerHTML = html;
        sidebarSitesSection.style.display = 'block';
        document.getElementById('sites-section').style.display = 'none';
    } else if (!isMobile) {
        const sitesGrid = document.getElementById('sites-grid');
        const sitesSection = document.getElementById('sites-section');
        sitesGrid.innerHTML = html;
        sitesSection.style.display = 'block';
        document.getElementById('sidebar-sites-section').style.display = 'none';
    }

    document.querySelectorAll('.site-link').forEach(link => {
        link.addEventListener('click', (e) => {
            e.preventDefault();
            const href = link.getAttribute('data-href');
            const shouldPopup = link.getAttribute('data-popup') === 'true';
            const isExternalUrl = href.startsWith('http://') || href.startsWith('https://');

            // Open external URLs in new window (avoid X-Frame-Options blocking), or if popup flag is set
            if (shouldPopup || isExternalUrl) {
                window.open(href, '_blank', 'width=1200,height=800,resizable=yes,scrollbars=yes');
            } else {
                frame.src = href;
                frame.style.display = 'block';
                dashboardView.style.display = 'none';
            }
        });
    });
}

function adjustIconSizes() {
    const layout = document.querySelector('.app')?.getAttribute('data-layout');
    if (!layout || layout === 'mobile') return;

    const isSidebarLayout = isSidebarStyleLayout();
    if (!isSidebarLayout) return;

    const sidebar = document.querySelector('.app-sidebar');
    const serviceMenu = document.querySelector('.service-menu');
    const sidebarSitesSection = document.querySelector('.sidebar-sites-section');

    if (!sidebar || !serviceMenu) return;

    const sidebarWidth = sidebar.offsetWidth;
    const sidebarPadding = 48; // 24px on each side
    const iconGap = 12;

    // Calculate service icon size
    const serviceItems = document.querySelectorAll('.service-menu .menu-item:not(.menu-separator)');
    const numServices = serviceItems.length;
    if (numServices > 0) {
        const availableWidth = sidebarWidth - sidebarPadding;
        const totalGapWidth = (numServices - 1) * iconGap;
        const serviceIconSize = Math.floor((availableWidth - totalGapWidth) / numServices);
        const constrainedServiceSize = Math.min(serviceIconSize, 56);

        document.querySelectorAll('.menu-icon').forEach(icon => {
            icon.style.width = constrainedServiceSize + 'px';
            icon.style.height = constrainedServiceSize + 'px';
        });
    }

    // Calculate site icon size (exactly half of service icon size)
    if (sidebarSitesSection) {
        const siteItems = document.querySelectorAll('.sidebar-sites-grid .site-link');
        const numSites = siteItems.length;
        if (numSites > 0) {
            const availableWidth = sidebarWidth - sidebarPadding;
            const totalGapWidth = (numSites - 1) * iconGap;
            const siteIconSize = Math.floor((availableWidth - totalGapWidth) / numSites / 2);
            const constrainedSiteSize = Math.min(siteIconSize, 28);

            document.querySelectorAll('.sidebar-sites-section .site-icon').forEach(icon => {
                icon.style.width = constrainedSiteSize + 'px';
                icon.style.height = constrainedSiteSize + 'px';
            });
        }
    }
}

async function checkConfiguredServices() {
    // Always build menus and sites, regardless of dashboard landing or API configuration
    await buildServiceMenu();
    await buildSitesGrid();
    adjustIconSizes();

    const layout = document.querySelector('.app')?.getAttribute('data-layout');
    const isFocusLayout = layout === 'focus';

    // A configured landing page always wins, independent of API/service status -
    // except on the focus layout, which has no sidebar and relies entirely on the
    // dashboard card grid to switch between services, so it must stay visible.
    if (DASHBOARD_LANDING && !isFocusLayout) {
        frame.src = '/' + DASHBOARD_LANDING.replace(/^\/+/, '');
        frame.style.display = 'block';
        dashboardView.style.display = 'none';
        welcomeScreen.style.display = 'none';
        return;
    }

    try {
        const response = await fetch(`/health`);
        const health = await response.json();
        const hasAnyConfigured = Object.values(health.services || {}).some(s => s.configured);

        if (!hasAnyConfigured && !isFocusLayout) {
            dashboardView.style.display = 'none';
            welcomeScreen.style.display = 'flex';
            return;
        }

        loadDashboard();
        setInterval(loadDashboard, 30000);
    } catch (err) {
        console.error('[Health Check] Error:', err);
        // If health check fails, show welcome screen (unless focus layout)
        if (!isFocusLayout) {
            dashboardView.style.display = 'none';
            welcomeScreen.style.display = 'flex';
        } else {
            loadDashboard();
            setInterval(loadDashboard, 30000);
        }
    }
}

// Logo/name click in the header or footer - stay on the current layout's page
// and return to its service panel instead of navigating to "/" (which loads
// whatever DASH_STYLE default the server is configured with).
function goHome(e) {
    e.preventDefault();
    frame.style.display = 'none';
    frame.src = '';
    welcomeScreen.style.display = 'none';
    dashboardView.style.display = 'flex';
    loadDashboard();
    return false;
}

// Adjust icon sizes on window resize
window.addEventListener('resize', () => {
    adjustIconSizes();
});

checkConfiguredServices();

// Injected by build script - contains all detected layouts (core + custom + demos)
@@AVAILABLE_TEMPLATES@@
// Exclude mobile from the template slider (always available but not in switcher)
let availableTemplates = AVAILABLE_TEMPLATES.filter(t => t !== 'mobile');

function initFooter() {
    const sliders = document.querySelectorAll('.template-slider');
    const slider = sliders[sliders.length - 1]; // Get the footer slider (last one)
    const labels = document.querySelectorAll('.template-label');
    const label = labels[labels.length - 1]; // Get the footer label (last one)
    const themeToggle = document.getElementById('themeToggle');
    const app = document.querySelector('.app');

    // Get current template from data-layout attribute
    let currentTemplate = app.getAttribute('data-layout');
    const currentTheme = app.getAttribute('data-theme');

    // Check if dashboard is locked to a single template
    const isLocked = localStorage.getItem('dashboard-locked') === 'true';

    if (isLocked) {
      // Hide the slider and label when locked
      slider.style.display = 'none';
      label.style.display = 'none';
    } else {
      // Setup template slider with correct max value
      slider.max = Math.max(0, availableTemplates.length - 1);
      const currentIndex = availableTemplates.indexOf(currentTemplate);
      slider.value = currentIndex >= 0 ? currentIndex : 0;
      label.textContent = currentTemplate || availableTemplates[slider.value];

      slider.addEventListener('input', (e) => {
          const index = parseInt(e.target.value);
          const template = availableTemplates[index];
          label.textContent = template;
          localStorage.setItem('dashboard-template', template);

          // Navigate to the selected template HTML file
          window.location.href = `/${template}.html`;
      });
    }

    // Setup theme toggle
    function updateThemeButton() {
        const theme = app.getAttribute('data-theme') || 'dark';
        themeToggle.textContent = theme === 'dark' ? '☀️' : '🌙';
    }

    themeToggle.addEventListener('click', () => {
        const currentTheme = app.getAttribute('data-theme') || 'dark';
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        app.setAttribute('data-theme', newTheme);
        localStorage.setItem('dashboard-theme', newTheme);
        updateThemeButton();
    });

    // Restore saved theme
    const savedTheme = localStorage.getItem('dashboard-theme');
    if (savedTheme) {
        app.setAttribute('data-theme', savedTheme);
    }
    updateThemeButton();

    // Update footer time
    function updateFooterTime() {
        const now = new Date();
        const timeEl = document.getElementById('footerTime');
        const dateEl = document.getElementById('footerDate');
        if (timeEl) timeEl.textContent = now.toLocaleTimeString('en-AU', {hour: '2-digit', minute: '2-digit'});
        if (dateEl) dateEl.textContent = now.toLocaleDateString('en-AU', {weekday: 'short', month: 'short', day: 'numeric'});
    }
    updateFooterTime();
    setInterval(updateFooterTime, 1000);
}

initFooter();
</script>
