# Office 365 OpenID Connect Configuration for Subdomain Services (Emby/Plex)
# This configuration uses the subdomain as the RedirectURI hostname

# Client Configuration - Provided via environment variables
OIDCClientID @@OAUTH2_CLIENT_ID@@
OIDCClientSecret @@OAUTH2_CLIENT_SECRET@@
OIDCRedirectURI @@OAUTH2_REDIRECT_URI_SUBDOMAIN@@

# Azure AD Configuration - use tenant-specific endpoint
OIDCProviderMetadataURL @@OIDC_PROVIDER_METADATA_URL@@

# Scopes - what information to request from Office 365
OIDCScope "openid profile email"

# Session configuration
OIDCSessionInactivityTimeout 3600
OIDCSessionMaxDuration 86400

# Claim configuration
OIDCClaimPrefix OIDC_
OIDCPassClaimsAs environment

# Encryption
OIDCCryptoPassphrase "@@CRYPTO_PASSPHRASE@@"

# Validate SSL certificates (recommended for production)
OIDCSSLValidateServer On

# Claim settings
OIDCClaimDelimiter ;
OIDCPassUserInfoAs json
