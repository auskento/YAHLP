# Let's Encrypt Configuration
DOMAIN=yourdomain.com
EMAIL=your-email@example.com

# Timezone - Set to your location
TZ=Australia/Melbourne
# Media Server Managers (*arr applications)
ENABLE_SONARR=true
ENABLE_RADARR=true
ENABLE_WHISPARR=false
ENABLE_LIDARR=false
ENABLE_READARR=false
ENABLE_PROWLARR=false
ENABLE_OVERSEERR=false

# Media Centers
ENABLE_JELLYFIN=false
ENABLE_EMBY=false
ENABLE_PLEX=false
ENABLE_TAUTULLI=false

# Torrent Clients
ENABLE_TRANSMISSION=false
ENABLE_QBITTORRENT=false
ENABLE_SABNZBD=false
ENABLE_DELUGE=false

# SERVICE BACKEND URLs
# Specify the address of each service the proxy should forward requests to
# Examples:
#   Docker container on same network: http://sonarr:8989
#   Local IP address: http://192.168.1.100:8989
#   External service: http://example.com:8989
SONARR_URL=http://sonarr:8989
RADARR_URL=http://radarr:7878
WHISPARR_URL=http://whisparr:6969
LIDARR_URL=http://lidarr:8686
READARR_URL=http://readarr:8787
PROWLARR_URL=http://prowlarr:9696
OVERSEERR_URL=http://overseerr:5055
JELLYFIN_URL=http://jellyfin:8096
EMBY_URL=http://emby:8096
PLEX_URL=http://plex:32400
TAUTULLI_URL=http://tautulli:8181
TRANSMISSION_URL=http://transmission:6969
QBITTORRENT_URL=http://qbittorrent:8080
SABNZBD_URL=http://sabnzbd:8080
DELUGE_URL=http://deluge:8112

# Custom Backend (for proxying to services not in the list)
ENABLE_CUSTOM_BACKEND=false
CUSTOM_BACKEND_PATH=/custom
CUSTOM_BACKEND_URL=http://backend:8080

# App Icons - Leave blank to use auto-generated colored squares
# Icons will be auto-downloaded and resized to 100x100
# Examples:
#   https://github.com/Sonarr/Sonarr/raw/develop/Logo/256.png
#   https://raw.githubusercontent.com/linuxserver/docker-templates/.../sonarr-icon.png
ICON_URL_SONARR=""
ICON_URL_RADARR=""
ICON_URL_WHISPARR=""
ICON_URL_LIDARR=""
ICON_URL_READARR=""
ICON_URL_PROWLARR=""
ICON_URL_OVERSEERR=""
ICON_URL_JELLYFIN=""
ICON_URL_EMBY=""
ICON_URL_PLEX=""
ICON_URL_TAUTULLI=""
ICON_URL_TRANSMISSION=""
ICON_URL_QBITTORRENT=""
ICON_URL_SABNZBD=""
ICON_URL_DELUGE=""

# Basic Authentication (Optional)
# Set ENABLE_BASIC_AUTH=true to require username/password for all proxy access
# BASIC_AUTH_CREDENTIALS format: "username:password|username2:password2" (pipe-separated pairs)
ENABLE_BASIC_AUTH=false
BASIC_AUTH_CREDENTIALS=""

# Office 365 / Azure AD Authentication (Optional)
ENABLE_AUTH_OFFICE365=false
OAUTH2_CLIENT_ID=""
OAUTH2_CLIENT_SECRET=""
OAUTH2_REDIRECT_URI="https://yourdomain.com/oauth2callback"
OAUTH2_ALLOWED_DOMAINS="example.com"
OAUTH2_CRYPTO_PASSPHRASE=""

# SSL Configuration (advanced)
SSL_PROTOCOLS=all -SSLv2 -SSLv3 -TLSv1 -TLSv1.1
SSL_CIPHERS=HIGH:!aNULL:!MD5

# Apache Log Level (debug, info, notice, warn, crit)
APACHE_LOG_LEVEL=warn

# Dashboard Customization
DASHBOARD_NAME=Media Server
DASHBOARD_ICON=/icons/apache-reverse-proxy-logo.png
