# Deployment Mode (public/private)
ACCESS_MODE=public

# Domain & SSL (required for public mode)
DOMAIN=yourdomain.com
EMAIL=your-email@example.com
DASHBOARD_TEST=true

# Local IP (required for private mode)
IP=

# Container Permissions
PUID=0
PGID=0

# Dashboard Settings
DASHBOARD_NAME=YAHLP
DASHBOARD_COLOR=#1a1a1a
DASHBOARD_STYLE=modern
DASHBOARD_ORDER=SAB,GET,HYD,TRA,QBI,DEL,PRO,JAC,SON,RAD,LID,WHI,SEE,BAZ,TAU,MNT,JEL,PLX,EMB
DASHBOARD_LANDING=
DASHBOARD_WINDOWS=popout
DASHBOARD_SITES=

# Authentication (none/basic/entra/google)
AUTHTYPE=none
BASIC_AUTH_CREDENTIALS=""
ENTRA_CLIENT_ID=""
ENTRA_CLIENT_SECRET=""
ENTRA_PROVIDER_METADATA_URL=""
ENTRA_CRYPTO_PASSPHRASE=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CRYPTO_PASSPHRASE=""

# Usenet Clients
SABNZBD_ENABLED=false
SABNZBD_URL=http://sabnzbd:8080
SABNZBD_API_KEY=""
NZBGET_ENABLED=false
NZBGET_URL=http://nzbget:6789
NZBGET_USERNAME=""
NZBGET_PASSWORD=""
NZBHYDRA_ENABLED=false
NZBHYDRA_URL=http://nzbhydra:5076
NZBHYDRA_API_KEY=""

# Torrent Clients
TRANSMISSION_ENABLED=false
TRANSMISSION_URL=http://transmission:9091
TRANSMISSION_PASSWORD=""
QBITTORRENT_ENABLED=false
QBITTORRENT_URL=http://qbittorrent:8080
QBITTORRENT_API_KEY=""
DELUGE_ENABLED=false
DELUGE_URL=http://deluge:8112
DELUGE_PASSWORD=""

# Content Managers
SONARR_ENABLED=false
SONARR_URL=http://sonarr:8989
SONARR_API_KEY=""
SONARR_LANDING=
RADARR_ENABLED=false
RADARR_URL=http://radarr:7878
RADARR_API_KEY=""
RADARR_LANDING=
WHISPARR_ENABLED=false
WHISPARR_URL=http://whisparr:6969
WHISPARR_API_KEY=""
LIDARR_ENABLED=false
LIDARR_URL=http://lidarr:8686
LIDARR_API_KEY=""
LIDARR_LANDING=

# Indexers
PROWLARR_ENABLED=false
PROWLARR_URL=http://prowlarr:9696
PROWLARR_API_KEY=""
JACKETT_ENABLED=false
JACKETT_URL=http://jackett:9117
JACKETT_API_KEY=""

# Requests & Utilities
SEERR_ENABLED=false
SEERR_URL=http://seerr:5055
SEERR_API_KEY=""
BAZARR_ENABLED=false
BAZARR_URL=http://bazarr:6767
BAZARR_API_KEY=""
TAUTULLI_ENABLED=false
TAUTULLI_URL=http://tautulli:8181
TAUTULLI_API_KEY=""
MAINTAINERR_ENABLED=false
MAINTAINERR_URL=http://maintainerr:6246
MAINTAINERR_API_KEY=""

# Media Servers
JELLYFIN_ENABLED=false
JELLYFIN_URL=http://jellyfin:8096
JELLYFIN_API_KEY=""
JELLYFIN_USERNAME=""
JELLYFIN_PASSWORD=""
EMBY_ENABLED=false
EMBY_URL=http://emby:8096
EMBY_API_KEY=""
PLEX_ENABLED=false
PLEX_URL=http://plex:32400
PLEX_API_KEY=""

# Service Subdomains (public mode only)
PLEX_DOMAIN=
EMBY_DOMAIN=
SEERR_DOMAIN=
JACKETT_DOMAIN=

# SSL/TLS Configuration (advanced)
SSL_PROTOCOLS=all -SSLv2 -SSLv3 -TLSv1 -TLSv1.1
SSL_CIPHERS=HIGH:!aNULL:!MD5
APACHE_LOG_LEVEL=warn
