# Deployment Mode
ACCESS_MODE=public

# Let's Encrypt Configuration
DOMAIN=yourdomain.com
EMAIL=your-email@example.com
TEST=true                                     # Set to false to go live (Let's Encrpyt certificates issues)

# Timezone - Set to your location (optional, defaults to container default)
TZ=

# Dashboard Customization (DASH section)
DASH_STYLE=modern                             # modern, classic, sleek, minimal (append :only to disable theme switcher)
DASHBOARD_THEME=dark                          # dark (default) or light
DASHBOARD_NAME=YAHLP                          # Custom dashboard title
DASHBOARD_COLOR=#1a1a1a                       # Menu background color (6-digit hex code)
DASHBOARD_ICON_URL=                           # Optional: URL to download custom dashboard icon
DASHBOARD_LANDING=                            # Optional: default service/page on dashboard load
DASHBOARD_ORDER=SAB,GET,HYD,TRA,QBI,DEL,PRO,JAC,SON,RAD,LID,WHI,SEE,BAZ,TAU,MNT,JEL,PLX,EMB

# Built-in Torrent/Usenet Sites (enabled via DASHBOARD_SITES)
# Comma-separated site codes to enable
# Torrent: TPB, FIL, HDB, IPT, 1337, YTS, LAT, NYA, PTP
# Usenet: DOG, DRS, NLF, NFW, NGK, PLA, TAB
# Example: DASHBOARD_SITES=TPB,DOG,NLF
# If empty, only custom sites from sites.json5 are shown
DASHBOARD_SITES=

# Services - Enable/Disable (ordered by DASHBOARD_ORDER)
ENABLE_SABNZBD=false
ENABLE_NZBGET=false
ENABLE_NZBHYDRA=false
ENABLE_TRANSMISSION=false
ENABLE_QBITTORRENT=false
ENABLE_DELUGE=false
ENABLE_SONARR=false
SONARR_LANDING=
ENABLE_RADARR=false
RADARR_LANDING=
ENABLE_LIDARR=false
LIDARR_LANDING=
ENABLE_WHISPARR=false
ENABLE_PROWLARR=false
ENABLE_JACKETT=false
ENABLE_SEERR=false
ENABLE_BAZARR=false
ENABLE_JELLYFIN=false
ENABLE_EMBY=false
ENABLE_PLEX=false
ENABLE_TAUTULLI=false
ENABLE_MAINTAINERR=false

# SERVICE BACKEND URLs
# Specify the address of each service the proxy should forward requests to
# Examples:
#   Docker container on same network: http://sonarr:8989
#   Local IP address: http://192.168.1.100:8989
#   External service: http://example.com:8989

# Service Backend URLs (ordered by DASHBOARD_ORDER)
SABNZBD_URL=http://sabnzbd:8080
NZBGET_URL=http://nzbget:6789
NZBGET_USER=""
NZBGET_PASS=""
NZBHYDRA_URL=http://nzbhydra:5076
TRANSMISSION_URL=http://transmission:9091
QBITTORRENT_URL=http://qbittorrent:8080
DELUGE_URL=http://deluge:8112
SONARR_URL=http://sonarr:8989
RADARR_URL=http://radarr:7878
LIDARR_URL=http://lidarr:8686
WHISPARR_URL=http://whisparr:6969
PROWLARR_URL=http://prowlarr:9696
JACKETT_URL=http://jackett:9117
SEERR_URL=http://seerr:5055
SEERR_DOMAIN=seerr.yourdomain.com
SEERR_REDIRECT_URI=https://seerr.yourdomain.com/oauth2callback
BAZARR_URL=http://bazarr:6767
JELLYFIN_URL=http://jellyfin:8096
EMBY_URL=http://emby:8096
EMBY_DOMAIN=emby.yourdomain.com
EMBY_REDIRECT_URI=https://emby.yourdomain.com/oauth2callback
PLEX_URL=http://plex:32400
PLEX_DOMAIN=plex.yourdomain.com
PLEX_REDIRECT_URI=https://plex.yourdomain.com/oauth2callback
TAUTULLI_URL=http://tautulli:8181
MAINTAINERR_URL=http://maintainerr:6246

# App Icons - Leave blank to use auto-generated colored squares
# Icons will be auto-downloaded and resized to 100x100
# Examples:
#   https://github.com/Sonarr/Sonarr/raw/develop/Logo/256.png
#   https://raw.githubusercontent.com/linuxserver/docker-templates/.../sonarr-icon.png

# Service Icons (ordered by DASHBOARD_ORDER)
SERVICE_ICON_URL_SABNZBD=""
SERVICE_ICON_URL_NZBGET=""
SERVICE_ICON_URL_NZBHYDRA=""
SERVICE_ICON_URL_TRANSMISSION=""
SERVICE_ICON_URL_QBITTORRENT=""
SERVICE_ICON_URL_DELUGE=""
SERVICE_ICON_URL_SONARR=""
SERVICE_ICON_URL_RADARR=""
SERVICE_ICON_URL_LIDARR=""
SERVICE_ICON_URL_WHISPARR=""
SERVICE_ICON_URL_PROWLARR=""
SERVICE_ICON_URL_JACKETT=""
SERVICE_ICON_URL_SEERR=""
SERVICE_ICON_URL_BAZARR=""
SERVICE_ICON_URL_JELLYFIN=""
SERVICE_ICON_URL_EMBY=""
SERVICE_ICON_URL_PLEX=""
SERVICE_ICON_URL_TAUTULLI=""
SERVICE_ICON_URL_MAINTAINERR=""

# Authentication Method (Choose one: none, basic, entra, google)
# - none: No authentication required (default)
# - basic: HTTP Basic Auth with htpasswd credentials (forces classic interface)
# - entra: Microsoft Entra ID (Azure AD) OAuth2
# - google: Google OAuth2
AUTHTYPE=none

# Basic Authentication (Required if AUTHTYPE=basic)
# Format: "username:password|username2:password2" (pipe-separated pairs)
BASIC_AUTH_CREDENTIALS=""

# Entra ID (Microsoft) Authentication (Required if AUTHTYPE=entra)
ENTRA_CLIENT_ID=""
ENTRA_CLIENT_SECRET=""
ENTRA_REDIRECT_URI="https://yourdomain.com/auth/oauth2/callback"
ENTRA_PROVIDER_METADATA_URL=""
ENTRA_CRYPTO_PASSPHRASE=""

# Google Authentication (Required if AUTHTYPE=google)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://yourdomain.com"

# SSL Configuration (advanced)
SSL_PROTOCOLS=all -SSLv2 -SSLv3 -TLSv1 -TLSv1.1
SSL_CIPHERS=HIGH:!aNULL:!MD5

# Apache Log Level (debug, info, notice, warn, crit)
APACHE_LOG_LEVEL=warn
