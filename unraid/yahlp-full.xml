  <Description>YAHLP - Complete Master Template with ALL configuration options visible</Description>
  <Overview>YAHLP - Yet Another HomeLab Portal - Full Configuration Template with all 19 services and complete settings</Overview>

  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>80</HostPort>
        <ContainerPort>80</ContainerPort>
        <Protocol>tcp</Protocol>
        <Description>HTTP</Description>
        <Access>External</Access>
      </Port>
      <Port>
        <HostPort>443</HostPort>
        <ContainerPort>443</ContainerPort>
        <Protocol>tcp</Protocol>
        <Description>HTTPS</Description>
        <Access>External</Access>
      </Port>
    </Publish>
  </Networking>

  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/yahlp/letsencrypt</HostDir>
      <ContainerDir>/etc/letsencrypt</ContainerDir>
      <Mode>rw</Mode>
      <Description>SSL Certificates</Description>
      <Access>rw</Access>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/yahlp/config</HostDir>
      <ContainerDir>/etc/yahlp</ContainerDir>
      <Mode>rw</Mode>
      <Description>Configuration</Description>
      <Access>rw</Access>
    </Volume>
  </Data>

