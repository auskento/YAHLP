<?xml version="1.0" encoding="utf-8"?>
<Container version="2">
  <Name>YAHLP</Name>
  <Repository>auskento/yahlp</Repository>
  <Registry>https://hub.docker.com/r/auskento/yahlp</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/auskento/YAHLP</Support>
  <Project>https://github.com/auskento/YAHLP</Project>
  <Category>Network:Web</Category>
  <TemplateURL>https://raw.githubusercontent.com/auskento/YAHLP/main/unraid/yahlp-full.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/auskento/YAHLP/main/html/icons/yahlp.png</Icon>
  <WebUI>https://[IP]:[PORT:443]</WebUI>
  <CloudSync>false</CloudSync>
  <Description>YAHLP - Yet Another Home Lab Portal. Complete dashboard with ALL services and settings available.</Description>
  <Overview>YAHLP Dashboard - Complete Master Template with ALL available configuration options for services, authentication, and dashboard customization.</Overview>

  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>80</HostPort>
        <ContainerPort>80</ContainerPort>
        <Protocol>tcp</Protocol>
        <Description>HTTP</Description>
        <Access>External</Access>
      </Port>
      <Port>
        <HostPort>443</HostPort>
        <ContainerPort>443</ContainerPort>
        <Protocol>tcp</Protocol>
        <Description>HTTPS</Description>
        <Access>External</Access>
      </Port>
    </Publish>
  </Networking>

  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/yahlp/letsencrypt</HostDir>
      <ContainerDir>/etc/letsencrypt</ContainerDir>
      <Mode>rw</Mode>
      <Description>SSL Certificates</Description>
      <Access>rw</Access>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/yahlp/config</HostDir>
      <ContainerDir>/etc/yahlp</ContainerDir>
      <Mode>rw</Mode>
      <Description>Configuration Files</Description>
      <Access>rw</Access>
    </Volume>
  </Data>

  <Environment>
    <!-- TESTING -->
    <Variable>
      <Name>TEST_MODE</Name>
      <Value>false</Value>
    </Variable>

    <!-- DEPLOYMENT SETTINGS -->
    <Variable>
      <Name>ACCESS_MODE</Name>
      <Value>private</Value>
    </Variable>
    <Variable>
      <Name>DOMAIN</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>EMAIL</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>IP</Name>
      <Value></Value>
    </Variable>

    <!-- DASHBOARD SETTINGS -->
    <Variable>
      <Name>DASHBOARD_NAME</Name>
      <Value>YAHLP Dashboard</Value>
    </Variable>
    <Variable>
      <Name>DASHBOARD_COLOR</Name>
      <Value>#00A99D</Value>
    </Variable>
    <Variable>
      <Name>DASHBOARD_STYLE</Name>
      <Value>modern</Value>
    </Variable>
    <Variable>
      <Name>DASHBOARD_LOCKED</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>DASHBOARD_ORDER</Name>
      <Value>JEL,PLX,EMB,SON,RAD,LID,WHI,QBI,TRA,SAB,GET,DEL,HYD,PRO,SEE,JAC,BAZ,TAU,MNT</Value>
    </Variable>
    <Variable>
      <Name>DASHBOARD_LANDING</Name>
      <Value></Value>
    </Variable>

    <!-- AUTHENTICATION SETTINGS -->
    <Variable>
      <Name>AUTHTYPE</Name>
      <Value>none</Value>
    </Variable>
    <Variable>
      <Name>BASIC_AUTH_USER</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>BASIC_AUTH_PASS</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>GOOGLE_CLIENT_ID</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>GOOGLE_CLIENT_SECRET</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>GOOGLE_REDIRECT_URI</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>ENTRA_CLIENT_ID</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>ENTRA_CLIENT_SECRET</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>ENTRA_TENANT_ID</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>ENTRA_REDIRECT_URI</Name>
      <Value></Value>
    </Variable>

    <!-- MEDIA SERVERS -->
    <Variable>
      <Name>ENABLE_JELLYFIN</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>JELLYFIN_URL</Name>
      <Value>http://jellyfin:8096</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_PLEX</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>PLEX_URL</Name>
      <Value>http://plex:32400</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_EMBY</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>EMBY_URL</Name>
      <Value>http://emby:8096</Value>
    </Variable>

    <!-- PVR MANAGERS -->
    <Variable>
      <Name>ENABLE_SONARR</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>SONARR_URL</Name>
      <Value>http://sonarr:8989</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_RADARR</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>RADARR_URL</Name>
      <Value>http://radarr:7878</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_LIDARR</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>LIDARR_URL</Name>
      <Value>http://lidarr:8686</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_WHISPARR</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>WHISPARR_URL</Name>
      <Value>http://whisparr:6969</Value>
    </Variable>

    <!-- INDEXERS & SEARCH -->
    <Variable>
      <Name>ENABLE_PROWLARR</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>PROWLARR_URL</Name>
      <Value>http://prowlarr:9696</Value>
    </Variable>
    <Variable>
      <Name>PROWLARR_API_KEY</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>ENABLE_JACKETT</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>JACKETT_URL</Name>
      <Value>http://jackett:9117</Value>
    </Variable>
    <Variable>
      <Name>JACKETT_API_KEY</Name>
      <Value></Value>
    </Variable>

    <!-- REQUEST MANAGEMENT -->
    <Variable>
      <Name>ENABLE_SEERR</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>SEERR_URL</Name>
      <Value>http://seerr:5055</Value>
    </Variable>
    <Variable>
      <Name>SEERR_API_KEY</Name>
      <Value></Value>
    </Variable>

    <!-- TORRENT CLIENTS -->
    <Variable>
      <Name>ENABLE_QBITTORRENT</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>QBITTORRENT_URL</Name>
      <Value>http://qbittorrent:8080</Value>
    </Variable>
    <Variable>
      <Name>QBITTORRENT_API_KEY</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>ENABLE_TRANSMISSION</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>TRANSMISSION_URL</Name>
      <Value>http://transmission:9091</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_DELUGE</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>DELUGE_URL</Name>
      <Value>http://deluge:8112</Value>
    </Variable>
    <Variable>
      <Name>DELUGE_API_KEY</Name>
      <Value></Value>
    </Variable>

    <!-- USENET CLIENTS -->
    <Variable>
      <Name>ENABLE_SABNZBD</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>SABNZBD_URL</Name>
      <Value>http://sabnzbd:8080</Value>
    </Variable>
    <Variable>
      <Name>SABNZBD_API_KEY</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>ENABLE_NZBGET</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>NZBGET_URL</Name>
      <Value>http://nzbget:6789</Value>
    </Variable>
    <Variable>
      <Name>NZBGET_USER</Name>
      <Value>nzbget</Value>
    </Variable>
    <Variable>
      <Name>NZBGET_PASS</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>ENABLE_NZBHYDRA</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>NZBHYDRA_URL</Name>
      <Value>http://nzbhydra:5076</Value>
    </Variable>
    <Variable>
      <Name>NZBHYDRA_API_KEY</Name>
      <Value></Value>
    </Variable>

    <!-- MANAGEMENT TOOLS -->
    <Variable>
      <Name>ENABLE_TAUTULLI</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>TAUTULLI_URL</Name>
      <Value>http://tautulli:8181</Value>
    </Variable>
    <Variable>
      <Name>TAUTULLI_API_KEY</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>ENABLE_MAINTAINERR</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>MAINTAINERR_URL</Name>
      <Value>http://maintainerr:6246</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_BAZARR</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>BAZARR_URL</Name>
      <Value>http://bazarr:6767</Value>
    </Variable>

    <!-- ENVIRONMENT -->
    <Variable>
      <Name>TZ</Name>
      <Value>Etc/UTC</Value>
    </Variable>
  </Environment>

</Container>
